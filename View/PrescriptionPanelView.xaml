<UserControl x:Class="TamAnh_EMR_System.View.PrescriptionPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="LeftText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2FFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <fa:IconImage Icon="Search" Height="20" Width="20" Foreground="{StaticResource plainTextColor3}"/>
                <TextBox Width="320"
                         Height="24"
                         Margin="5,5,0,0"
                         FontSize="13"
                         FontWeight="Medium"
                         FontFamily="Montserrat"
                         Background="Transparent"
                         BorderBrush="{StaticResource plainTextColor3}"
                         BorderThickness="0,0,0,1"
                         Foreground="{StaticResource plainTextColor3}"
                         CaretBrush="{StaticResource plainTextColor3}"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Margin="0,10,0,0" Padding="15" Background="{StaticResource panelColor}" CornerRadius="15">
            <DataGrid ItemsSource="{Binding Prescriptions}"
                      SelectedItem="{Binding SelectedPrescription}"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="42"
                      RowHeaderWidth="0"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      Foreground="{StaticResource titleColor1}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="{StaticResource plainTextColor3}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource panelOverColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource panelActiveColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{StaticResource color8}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontFamily" Value="Montserrat"/>
                        <Setter Property="Margin" Value="10,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã bệnh án" Binding="{Binding RecordId}" Width="120" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Bệnh nhân" Binding="{Binding MedicalRecord.Patient.Name}" Width="220" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Chẩn đoán" Binding="{Binding MedicalRecord.Diagnosis}" Width="260" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Bác sĩ" Binding="{Binding MedicalRecord.Doctor.FullName}" Width="200" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Số loại thuốc" Binding="{Binding PrescriptionDetails.Count}" Width="120" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Ngày kê" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="140" ElementStyle="{StaticResource LeftText}"/>

                    <DataGridTemplateColumn Header="Thao tác" Width="120">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FontFamily" Value="Montserrat"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.ViewPrescriptionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Margin="0,0,5,0">
                                        <fa:IconImage Icon="Eye" Width="18" Height="18" Foreground="#2196F3"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.EditPrescriptionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Margin="0,0,5,0">
                                        <fa:IconImage Icon="PenToSquare" Width="18" Height="18" Foreground="#4CAF50"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}" Command="{Binding DataContext.DeletePrescriptionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                        <fa:IconImage Icon="RectangleXmark" Width="18" Height="18" Foreground="#F44336"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.RowSpan="2" Panel.ZIndex="999" Visibility="{Binding IsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#66000000">
            <Border Width="1000" Height="700" CornerRadius="20" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource color8}" CornerRadius="20,0,0,20" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="150" Height="150">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Resource/Image/prescription.jpg" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding PopupTitle}" FontSize="20" FontFamily="Montserrat" FontWeight="Bold" Margin="0,20,0,5" TextAlignment="Center"/>
                            <TextBlock Text="Thông tin đơn thuốc" FontSize="12" Opacity="0.7" TextAlignment="Center"/>
                            <Border Margin="0,30,0,0" Padding="15" CornerRadius="12" Background="#22FFFFFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Số loại thuốc" FontSize="15" Opacity="0.7" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="1" Text="{Binding CurrentPrescription.PrescriptionDetails.Count}" Foreground="#1D4ED8" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Style="{StaticResource controlButton}"
                                Command="{Binding ClosePopupCommand}"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0">
                            <fa:IconImage Icon="CircleXmark" Style="{StaticResource controlButtonIcon}" Width="20" Height="20"/>
                        </Button>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                            <StackPanel>
                                <Border Background="#F3F6F9" CornerRadius="10" Padding="16" Margin="0,0,0,24">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Bệnh nhân" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentPrescription.MedicalRecord.Patient.Name}" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Bác sĩ kê đơn" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentPrescription.MedicalRecord.Doctor.FullName}" IsReadOnly="True"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="Capsules" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Danh sách thuốc" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding CurrentPrescription.PrescriptionDetails}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">

                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding Medicine.Name}" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                                        <Border Background="#DBEAFE" CornerRadius="20" Padding="10,4" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding Quantity, StringFormat=Số lượng: {0}}" FontSize="11" FontWeight="SemiBold" Foreground="#2563EB"/>
                                                        </Border>
                                                    </DockPanel>

                                                    <TextBlock Text="{Binding Medicine.Category, StringFormat=Loại thuốc: {0}}" FontSize="12" Foreground="#6B7280" Margin="0,0,0,12"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Liều dùng" FontSize="12" Foreground="#6B7280"/>
                                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding Dosage}" IsReadOnly="{Binding DataContext.IsViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Tần suất" FontSize="12" Foreground="#6B7280"/>
                                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding Frequency}" IsReadOnly="{Binding DataContext.IsViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Text="Ghi chú" Margin="0,12,0,0" FontSize="12" Foreground="#6B7280"/>
                                                    <TextBox Style="{StaticResource InputTextBox}" Height="60" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding Notes}" IsReadOnly="{Binding DataContext.IsViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="Đóng" 
                                    Width="90" 
                                    Height="34" 
                                    Margin="0,0,10,0" 
                                    Command="{Binding ClosePopupCommand}"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Button Content="Lưu"
                                    Width="90"
                                    Height="34"
                                    Margin="10,0,0,0"
                                    Background="#28C76F"
                                    Foreground="White"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Command="{Binding SavePrescriptionCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>