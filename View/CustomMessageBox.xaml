<Window x:Class="TamAnh_EMR_System.View.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="420"
        Height="200">

    <Border CornerRadius="10" Background="{Binding HeaderColor}">
        <Grid>

            <!-- ROW -->
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <TextBlock Text="{Binding Title}"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                <Button Click="Close_Click"
                        HorizontalAlignment="Right"
                        Width="30" Height="30"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">

                    <fa:IconBlock Icon="{x:Static fa:IconChar.Xmark}"
                                  Foreground="White"
                                  Width="14"
                                  Height="14"/>
                </Button>
            </Grid>

            <!-- BODY -->
            <Grid Grid.Row="1" Margin="3" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- ICON -->
                <Grid Width="45" Height="45" Grid.Column="0">
                    <Ellipse Fill="{Binding IconBackground}"/>

                    <fa:IconBlock Icon="{Binding Icon}"
                                  Foreground="White"
                                  Width="20"
                                  Height="20"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                </Grid>

                <!-- MESSAGE -->
                <TextBlock Grid.Column="1"
                           Margin="10"
                           Text="{Binding Message}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- BUTTONS -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="10"
                        Background="{StaticResource titleColor1}"
                        x:Name="ButtonPanel"/>
        </Grid>
    </Border>
</Window>