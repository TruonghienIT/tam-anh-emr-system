<UserControl x:Class="TamAnh_EMR_System.View.UserPanelView"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                 xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
                 xmlns:local="clr-namespace:TamAnh_EMR_System.View"
                 mc:Ignorable="d" 
                 d:DesignHeight="450" d:DesignWidth="800">

    <!-- ================= RESOURCES ================= -->
    <UserControl.Resources>


        <!-- ICON BUTTON STYLE -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                    Background="Transparent"
                                    CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2FFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXT ALIGN -->
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LeftText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- ================= LAYOUT ================= -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- ===== TOP BAR ===== -->
            <Grid Grid.Row="0">

                <!-- SEARCH -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top">

                    <fa:IconImage Icon="Search"
                                  Height="20"
                                  Width="20"
                                  Foreground="{StaticResource plainTextColor3}"/>

                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Width="350"
                             Height="24"
                             Background="Transparent"
                             FontWeight="Medium"
                             FontFamily="Montserrat"
                             Foreground="{StaticResource plainTextColor3}"
                             CaretBrush="{StaticResource plainTextColor3}"
                             BorderBrush="{StaticResource plainTextColor3}"
                             BorderThickness="0,0,0,1"
                             VerticalContentAlignment="Center"
                             Margin="5,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ===== TABLE ===== -->
            <Border Grid.Row="1"
                    Background="{StaticResource panelColor}"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,10,0,0">

                <DataGrid ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          Background="Transparent"
                          Foreground="{StaticResource titleColor1}"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowHeight="40"
                          RowHeaderWidth="0"
                          CanUserAddRows="False"
                          SelectionMode="Single">

                    <!-- HEADER STYLE -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource plainTextColor3}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="Padding" Value="10,5"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- ROW STYLE -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource panelOverColor}"/>
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource panelActiveColor}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- CELL STYLE -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{StaticResource color8}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontFamily" Value="Montserrat"/>
                            <Setter Property="Margin" Value="10,0,0,0"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <!-- COLUMNS -->
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"
                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130"
                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTemplateColumn Header="Password" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="******"
                                               Style="{StaticResource LeftText}" 
                                               FontSize="18"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="130"
                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Created At" Binding="{Binding CreatedDate}" Width="250"
                            ElementStyle="{StaticResource LeftText}" />

                        <DataGridTextColumn Header="Updated At" Binding="{Binding UpdatedDate}" Width="*"
                            ElementStyle="{StaticResource LeftText}" />

                        <!-- CONTROL COLUMN -->
                        <DataGridTemplateColumn Header="Thao tác" Width="90">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="FontFamily" Value="Montserrat"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <!-- EDIT -->
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,5,0">

                                            <fa:IconImage Icon="PenToSquare"
                                                          Foreground="#4CAF50"
                                                          Width="18"
                                                          Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
  
        
        <Grid Visibility="{Binding IsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
        Background="Transparent">
        <Border Width="550"
        Height="350"
        CornerRadius="20"
        Background="White"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== LEFT PANEL ===== -->
                    <Border Background="{StaticResource color8}"
                    CornerRadius="20,0,0,20"
                    Padding="20">

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <Ellipse Width="120" Height="120">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Resource/Image/doctor.jpg" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding PopupTitle}"
                           FontSize="18"
                           FontFamily="Montserrat"
                           FontWeight="Bold"
                           Margin="0,20,0,5"
                           TextAlignment="Center"/>

                            <TextBlock Text="Nhập thông tin tài khoản"
                           FontSize="12"
                           FontFamily="Montserrat"
                           TextAlignment="Center"
                           Opacity="0.7"/>

                        </StackPanel>
                    </Border>

                    <!-- ===== RIGHT FORM ===== -->
                    <Grid Grid.Column="1" Margin="30">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CLOSE -->
                        <Button
                    Style="{StaticResource controlButton}"
                    Command="{Binding ClosePopupCommand}"
                    Tag="{StaticResource color4}"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0">
                            <fa:IconImage Icon="CircleXmark" Style="{StaticResource controlButtonIcon}" Height="20" Width="20"/>
                        </Button>


                        <!-- FORM -->
                        <StackPanel Grid.Row="1" Margin="0,9,0,0">

                            <TextBlock Text="Username" FontFamily="Montserrat"/>
                            <TextBox Text="{Binding CurrentUser.Username}" Height="30" Margin="0,5,0,10" FontFamily="Montserrat" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource color8}" Foreground="White" Background="{StaticResource color8}" FontSize="13"/>

                            <TextBlock Text="Password" FontFamily="Montserrat"/>
                            <TextBox Text="{Binding CurrentUser.Password}" Height="30" Margin="0,5" FontFamily="Montserrat" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="{StaticResource color8}" Foreground="White" Background="{StaticResource color8}" FontSize="13"/>

                        </StackPanel>

                        <!-- BUTTON -->
                        <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                            <Button 
                            Content="Hủy" 
                            Command="{Binding ClosePopupCommand}" 
                            FontFamily="Montserrat" 
                            Width="80" Height="20" 
                            Margin="0,0,10,0"/>

                            <Button 
                            Content="Lưu" 
                            FontFamily="Montserrat" 
                            Command="{Binding SaveUserCommand}" 
                            Width="80" Height="20" 
                            Background="#28C76F" 
                            Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>