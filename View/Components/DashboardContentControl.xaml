<UserControl x:Class="TamAnh_EMR_System.View.Components.DashboardContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:TamAnh_EMR_System.View.Components">

    <!-- ================================================================
         DASHBOARD CONTENT CONTROL
         
         Contains the dashboard main content that was previously 
         hardcoded in ReceptionistView.xaml.
         
         Extracted into its own UserControl so that ReceptionistView
         can switch between this and other views (RegisterPatientView,
         SearchPatientView, etc.) via ContentControl + CurrentView.
         
         DataContext is inherited from the parent ReceptionistView
         (ReceptionistDashboardViewModel).
         ================================================================ -->

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0">

        <StackPanel Margin="24,20,24,24">

            <!-- ===== Dashboard Title Section ===== -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{Binding DashboardTitle}"
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource DashTextPrimary}"/>
                <TextBlock Text="{Binding DashboardSubtitle}"
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="14"
                           Foreground="{StaticResource DashTextSecondary}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ===== Statistics Cards Row ===== -->
            <components:StatisticCardControl Margin="0,0,0,0"/>

            <!-- ===== Appointment Table ===== -->
            <components:AppointmentTableControl/>

            <!-- ===== Bottom Section: Notifications + Chart ===== -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <!-- Notifications panel: ~40% width -->
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="16"/>
                    <!-- Chart panel: ~60% width -->
                    <ColumnDefinition Width="6*"/>
                </Grid.ColumnDefinitions>

                <!-- Notifications Panel -->
                <components:NotificationPanel Grid.Column="0"/>

                <!-- Chart Panel -->
                <components:ChartPanel
                    Grid.Column="2"
                    DataContext="{Binding}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
