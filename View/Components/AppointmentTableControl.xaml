<UserControl x:Class="TamAnh_EMR_System.View.Components.AppointmentTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="Transparent" FontFamily="Segoe UI">

    <UserControl.Resources>
        <ControlTemplate x:Key="ModernComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                <Path Data="M0,0 L3,3 L6,0 Z" Fill="#6B7280" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" />
            </Border>
        </ControlTemplate>

        <Style x:Key="ModernFilterComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Padding" Value="12,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="MainBorder" Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" IsHitTestVisible="false"/>
                                    <ToggleButton Template="{StaticResource ModernComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Focusable="false"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" Margin="0,4,0,0">
                                <Border MinWidth="{Binding ActualWidth, ElementName=MainBorder}" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernOutlineButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPaginationButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="12" Padding="24" Margin="0,16,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.05"/>
        </Border.Effect>

        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Danh sách khám hôm nay" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <ComboBox Style="{StaticResource ModernFilterComboBox}" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,12,0"/>

                    <ComboBox Style="{StaticResource ModernFilterComboBox}" ItemsSource="{Binding DoctorOptions}" SelectedItem="{Binding SelectedDoctor}" Margin="0,0,16,0"/>

                    <Button Style="{StaticResource ModernOutlineButton}" Margin="0,0,12,0" Command="{Binding ResetFiltersCommand}">
                        <TextBlock Text="Đặt lại bộ lọc" FontSize="13"/>
                    </Button>

                    <Button Style="{StaticResource ModernOutlineButton}" Command="{Binding ExportReportCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Download" Width="14" Height="14" Foreground="#4B5563" Margin="0,0,8,0"/>
                            <TextBlock Text="Xuất báo cáo" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Background="#F9FAFB" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="THỜI GIAN" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                    <TextBlock Grid.Column="1" Text="BỆNH NHÂN" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                    <TextBlock Grid.Column="2" Text="BÁC SĨ" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                    <TextBlock Grid.Column="3" Text="DỊCH VỤ" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280"/>
                    <TextBlock Grid.Column="4" Text="TRẠNG THÁI" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="THAO TÁC" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Margin="0,32,0,32">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PagedAppointments.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Không có lịch hẹn" FontSize="18" FontWeight="Bold" Foreground="#374151" HorizontalAlignment="Center"/>
                    <TextBlock Text="Không tìm thấy dữ liệu phù hợp với bộ lọc hiện tại." FontSize="14" Foreground="#9CA3AF" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <ItemsControl ItemsSource="{Binding PagedAppointments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="16,14" Background="Transparent" CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Time}" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="20" Width="40" Height="40" Margin="0,0,12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding AvatarColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding PatientInitials}" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PatientName}" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                        <TextBlock Text="{Binding GenderAge}" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DoctorName}" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Department}" FontSize="12" Foreground="#6B7280" FontStyle="Italic" Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="{Binding Service}" FontSize="13" Foreground="#4B5563" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>

                                <Border Grid.Column="4" Background="{Binding Status, Converter={StaticResource StatusToBackgroundConverter}}" CornerRadius="12" Padding="10,6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold" Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <Button Grid.Column="5" Style="{StaticResource ModernIconButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="36" Height="36">
                                    <fa:IconImage Icon="EllipsisVertical" Width="16" Height="16" Foreground="#9CA3AF"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding PaginationText}" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <Button Style="{StaticResource ModernPaginationButton}" Command="{Binding NavigatePageCommand}" CommandParameter="{Binding CurrentPage, Converter={StaticResource PrevPageConverter}}">
                        <fa:IconImage Icon="ChevronLeft" Width="12" Height="12" Foreground="#6B7280"/>
                    </Button>

                    <ItemsControl ItemsSource="{Binding PageNumbers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Style="{StaticResource ModernPaginationButton}"
                                        Command="{Binding DataContext.NavigatePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Style="{StaticResource ModernPaginationButton}" CommandParameter="{Binding CurrentPage, Converter={StaticResource NextPageConverter}}">
                        <fa:IconImage Icon="ChevronRight" Width="12" Height="12" Foreground="#6B7280"/>
                    </Button>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>