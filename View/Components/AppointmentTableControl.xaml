<UserControl x:Class="TamAnh_EMR_System.View.Components.AppointmentTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:converters="clr-namespace:TamAnh_EMR_System.Converters">

    <!-- ================================================================
         APPOINTMENT TABLE CONTROL
         The main data table showing today's appointment list.
         Contains:
         - Title row with filter dropdowns + export button
         - Column headers
         - Data rows via ItemsControl bound to Appointments collection
         - Pagination bar
         
         Status badges use converters for dynamic color coding.
         No data is hardcoded — everything comes from ViewModel bindings.
         ================================================================ -->

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource DashCardStyle}" Margin="0,16,0,0">
        <StackPanel>

            <!-- ===== Table Header: Title + Filters + Export ===== -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Table title -->
                <TextBlock Grid.Column="0"
                           Text="Danh sách khám hôm nay"
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource DashTextPrimary}"
                           VerticalAlignment="Center"/>

                <!-- Filters and Export button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- Status filter dropdown -->
                    <ComboBox Style="{StaticResource DashFilterComboBox}"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Margin="0,0,8,0"/>

                    <!-- Doctor filter dropdown -->
                    <ComboBox Style="{StaticResource DashFilterComboBox}"
                              ItemsSource="{Binding DoctorOptions}"
                              SelectedItem="{Binding SelectedDoctor}"
                              Margin="0,0,12,0"/>

                    <!-- Export report button -->
                    <Button Style="{StaticResource DashOutlineButton}"
                            Command="{Binding ExportReportCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Download" Width="14" Height="14"
                                          Foreground="{StaticResource DashTextSecondary}"
                                          Margin="0,0,6,0"/>
                            <TextBlock Text="Xuất báo cáo"
                                       FontFamily="{StaticResource DashFontFamily}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Column Headers ===== -->
            <Border BorderBrush="{StaticResource DashDividerColor}"
                    BorderThickness="0,0,0,1" Padding="0,8,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>  <!-- THỜI GIAN -->
                        <ColumnDefinition Width="*"/>     <!-- BỆNH NHÂN -->
                        <ColumnDefinition Width="140"/>  <!-- BÁC SĨ -->
                        <ColumnDefinition Width="120"/>  <!-- DỊCH VỤ -->
                        <ColumnDefinition Width="110"/>  <!-- TRẠNG THÁI -->
                        <ColumnDefinition Width="80"/>   <!-- THAO TÁC -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="THỜI GIAN"
                               Style="{StaticResource DashTableHeaderText}"/>
                    <TextBlock Grid.Column="1" Text="BỆNH NHÂN"
                               Style="{StaticResource DashTableHeaderText}"/>
                    <TextBlock Grid.Column="2" Text="BÁC SĨ"
                               Style="{StaticResource DashTableHeaderText}"/>
                    <TextBlock Grid.Column="3" Text="DỊCH VỤ"
                               Style="{StaticResource DashTableHeaderText}"/>
                    <TextBlock Grid.Column="4" Text="TRẠNG THÁI"
                               Style="{StaticResource DashTableHeaderText}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="THAO TÁC"
                               Style="{StaticResource DashTableHeaderText}"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ===== Appointment Data Rows ===== -->
            <!-- ItemsControl renders one row per DashboardAppointment in the collection -->
            <ItemsControl ItemsSource="{Binding Appointments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource DashDividerColor}"
                                BorderThickness="0,0,0,1"
                                Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- TIME column -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Time}"
                                               FontFamily="{StaticResource DashFontFamily}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource DashTextPrimary}"/>
                                    <TextBlock Text="{Binding Date}"
                                               FontFamily="{StaticResource DashFontFamily}"
                                               FontSize="11"
                                               Foreground="{StaticResource DashTextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- PATIENT column (avatar + name + gender/age) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <!-- Patient initials avatar circle -->
                                    <Border CornerRadius="18" Width="36" Height="36"
                                            Margin="0,0,10,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding AvatarColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding PatientInitials}"
                                                   FontFamily="{StaticResource DashFontFamily}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PatientName}"
                                                   FontFamily="{StaticResource DashFontFamily}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashTextPrimary}"/>
                                        <TextBlock Text="{Binding GenderAge}"
                                                   FontFamily="{StaticResource DashFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DashTextMuted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- DOCTOR column -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DoctorName}"
                                               FontFamily="{StaticResource DashFontFamily}"
                                               FontSize="13"
                                               Foreground="{StaticResource DashTextPrimary}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Department}"
                                               FontFamily="{StaticResource DashFontFamily}"
                                               FontSize="11"
                                               Foreground="{StaticResource DashTextMuted}"
                                               FontStyle="Italic"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- SERVICE column -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Service}"
                                           FontFamily="{StaticResource DashFontFamily}"
                                           FontSize="13"
                                           Foreground="{StaticResource DashTextSecondary}"
                                           VerticalAlignment="Center"/>

                                <!-- STATUS column (color-coded badge using converters) -->
                                <Border Grid.Column="4"
                                        Background="{Binding Status, Converter={StaticResource StatusToBackgroundConverter}}"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Status dot indicator -->
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontFamily="{StaticResource DashFontFamily}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- ACTIONS column (three-dot menu) -->
                                <Button Grid.Column="5"
                                        Style="{StaticResource DashIconButton}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="32" Height="32">
                                    <fa:IconImage Icon="EllipsisVertical" Width="14" Height="14"
                                                  Foreground="{StaticResource DashTextMuted}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ===== Pagination Bar ===== -->
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pagination info text -->
                <TextBlock Grid.Column="0"
                           Text="{Binding PaginationText}"
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="13"
                           Foreground="{StaticResource DashTextMuted}"
                           VerticalAlignment="Center"/>

                <!-- Page number buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- Previous page arrow -->
                    <Button Style="{StaticResource DashPaginationButton}"
                            Command="{Binding NavigatePageCommand}"
                            CommandParameter="0">
                        <fa:IconImage Icon="ChevronLeft" Width="10" Height="10"
                                      Foreground="{StaticResource DashTextMuted}"/>
                    </Button>

                    <!-- Page 1 (active) -->
                    <Button Style="{StaticResource DashPaginationButtonActive}"
                            Content="1"
                            Command="{Binding NavigatePageCommand}"
                            CommandParameter="1"/>

                    <!-- Page 2 -->
                    <Button Style="{StaticResource DashPaginationButton}"
                            Content="2"
                            Command="{Binding NavigatePageCommand}"
                            CommandParameter="2"/>

                    <!-- Page 3 -->
                    <Button Style="{StaticResource DashPaginationButton}"
                            Content="3"
                            Command="{Binding NavigatePageCommand}"
                            CommandParameter="3"/>

                    <!-- Next page arrow -->
                    <Button Style="{StaticResource DashPaginationButton}"
                            Command="{Binding NavigatePageCommand}"
                            CommandParameter="99">
                        <fa:IconImage Icon="ChevronRight" Width="10" Height="10"
                                      Foreground="{StaticResource DashTextMuted}"/>
                    </Button>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
