<UserControl x:Class="TamAnh_EMR_System.View.Components.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">

    <Border Background="{StaticResource DashHeaderBackground}"
            BorderBrush="{StaticResource DashBorderColor}"
            BorderThickness="0,0,0,1"
            Padding="24,12">

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Search box takes available space -->
                <ColumnDefinition Width="*"/>
                <!-- Right-side icons and user info -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Search Box ===== -->
            <Grid Grid.Column="0" MaxWidth="500" HorizontalAlignment="Left">
                <TextBox Style="{StaticResource DashSearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="400"
                         FontSize="15"
                         Padding="16,0,10,0"/>
                <!-- Search icon overlay -->
                <fa:IconImage Icon="MagnifyingGlass" Width="14" Height="14"
                              Foreground="{StaticResource DashTextMuted}"
                              HorizontalAlignment="Left" Margin="15,0,15,0"
                              IsHitTestVisible="False"/>
                <!-- Placeholder text (hidden when user types) -->
                <TextBlock Text="      Tìm kiếm bệnh nhân, hồ sơ hoặc bác sĩ..."
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="13"
                           Foreground="{StaticResource DashTextMuted}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- ===== Right Side: Icons + User Info ===== -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Notification Bell -->
                <Button Style="{StaticResource DashIconButton}" Margin="0,0,4,0">
                    <Grid>
                        <fa:IconImage Icon="Bell" Width="18" Height="18"
                                      Foreground="{StaticResource DashTextSecondary}"/>
                        <!-- Notification count badge -->
                        <Border Background="#EF4444" CornerRadius="8"
                                Padding="4,1" MinWidth="16" Height="16"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-4,-4,0">
                            <TextBlock Text="{Binding NotificationCount}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       FontFamily="{StaticResource DashFontFamily}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Info/Help Icon -->
                <Button Style="{StaticResource DashIconButton}" Margin="0,0,8,0">
                    <Border Background="#EFF6FF" CornerRadius="6"
                            Width="28" Height="28">
                        <TextBlock Text="?" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource DashPrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="{StaticResource DashFontFamily}"/>
                    </Border>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="32" Background="{StaticResource DashDividerColor}"
                        Margin="4,0,12,0"/>

                <!-- User Avatar + Name -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- User avatar circle -->
                    <Border CornerRadius="20" Width="36" Height="36"
                            Margin="0,0,10,0" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#93C5FD" Offset="0"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <fa:IconImage Icon="User" Width="18" Height="18"
                                      Foreground="White"/>
                    </Border>

                    <!-- User display name -->
                    <TextBlock Text="{Binding UserDisplayName}"
                               FontFamily="{StaticResource DashFontFamily}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource DashTextPrimary}"
                               VerticalAlignment="Center"/>

                    <!-- Dropdown arrow -->
                    <fa:IconImage Icon="ChevronDown" Width="10" Height="10"
                                  Foreground="{StaticResource DashTextMuted}"
                                  Margin="8,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
