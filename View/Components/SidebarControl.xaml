<UserControl x:Class="TamAnh_EMR_System.View.Components.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">

    <Border Background="{StaticResource DashSidebarBackground}"
            BorderBrush="{StaticResource DashBorderColor}"
            BorderThickness="0,0,1,0"
            Width="220">

        <DockPanel LastChildFill="True">

            <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,16">

                <Button Style="{StaticResource DashSidebarBottomItem}"
                        Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="CircleQuestion" Width="16" Height="16" Foreground="{StaticResource DashTextMuted}" Margin="0,0,10,0"/>
                        <TextBlock Text="Hỗ trợ" FontSize="13.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource DashSidebarBottomItem}"
                        Margin="0,0,0,4"
                        Command="{Binding LogoutCommand}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="ArrowRightFromBracket" Width="16" Height="16" Foreground="{StaticResource DashTextMuted}" Margin="0,0,10,0"/>
                        <TextBlock Text="Đăng xuất" FontSize="13.5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding MenuNavigateCommand}"
                        CommandParameter="Hẹn lịch mới"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Stretch">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DashPrimaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Hẹn lịch mới">
                                    <Setter Property="Background" Value="{StaticResource DashPrimaryBlueLight}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBlue}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Hẹn lịch mới" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="16,20,16,20">
                    <Border Background="{StaticResource DashPrimaryBlue}"
                            CornerRadius="10" Width="40" Height="40"
                            Margin="0,0,10,0">
                        <fa:IconImage Icon="HospitalUser" Width="20" Height="20" Foreground="White"/>
                    </Border>
                    <TextBlock Text="TâmAnhHospital"
                               FontFamily="{StaticResource DashFontFamily}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource DashTextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Height="1" Background="{StaticResource DashDividerColor}" Margin="16,0"/>

                <StackPanel Margin="20,16,20,16">
                    <TextBlock Text="{Binding UserArea}"
                               FontFamily="{StaticResource DashFontFamily}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource DashTextPrimary}"/>
                    <TextBlock Text="{Binding UserSubtitle}"
                               FontFamily="{StaticResource DashFontFamily}"
                               FontSize="12"
                               Foreground="{StaticResource DashTextMuted}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                
                <Button Command="{Binding MenuNavigateCommand}" CommandParameter="Tổng quan">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DashSidebarMenuItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Tổng quan">
                                    <Setter Property="Background" Value="{StaticResource DashPrimaryBlueLight}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBlue}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="ChartLine" Width="18" Height="18" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,12,0"/>
                        <TextBlock Text="Tổng quan" VerticalAlignment="Center" FontFamily="{StaticResource DashFontFamily}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding MenuNavigateCommand}" CommandParameter="Tìm kiếm bệnh nhân">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DashSidebarMenuItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Tìm kiếm bệnh nhân">
                                    <Setter Property="Background" Value="{StaticResource DashPrimaryBlueLight}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBlue}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="UserGroup" Width="18" Height="18" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,12,0"/>
                        <TextBlock Text="Tìm kiếm bệnh nhân" VerticalAlignment="Center" FontFamily="{StaticResource DashFontFamily}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding MenuNavigateCommand}" CommandParameter="Đăng ký">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DashSidebarMenuItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Đăng ký">
                                    <Setter Property="Background" Value="{StaticResource DashPrimaryBlueLight}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBlue}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="UserPlus" Width="18" Height="18" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Margin="0,0,12,0"/>
                        <TextBlock Text="Đăng ký" VerticalAlignment="Center" FontFamily="{StaticResource DashFontFamily}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding MenuNavigateCommand}" CommandParameter="Lịch hẹn">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DashSidebarMenuItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Lịch hẹn">
                                    <Setter Property="Background" Value="{StaticResource DashPrimaryBlueLight}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBlue}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="CalendarCheck" Width="18" Height="18" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"  Margin="0,0,12,0"/>
                        <TextBlock Text="Lịch hẹn" VerticalAlignment="Center" FontFamily="{StaticResource DashFontFamily}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
