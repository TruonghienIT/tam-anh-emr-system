<UserControl x:Class="TamAnh_EMR_System.View.Components.ChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         CHART PANEL
         Bar chart showing hourly appointment density ("Mật độ lịch khám 24h tới").
         Contains:
         - Title with tab toggles (Theo giờ / Theo khoa)
         - Dual-bar chart rendered via ItemsControl
         - Hour labels below each bar group
         
         Each bar group has two bars (primary darker blue, secondary lighter blue).
         Bar heights are calculated from ChartDataPoint.Bar1Height/Bar2Height properties.
         ================================================================ -->

    <Border Style="{StaticResource DashCardStyle}">
        <StackPanel>

            <!-- ===== Chart Header: Title + Tab Toggles ===== -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Mật độ lịch khám (24h tới)"
                           FontFamily="{StaticResource DashFontFamily}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource DashTextPrimary}"
                           VerticalAlignment="Center"/>

                <!-- Tab toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource DashTabButtonActive}"
                            Content="Theo giờ" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource DashTabButton}"
                            Content="Theo khoa"/>
                </StackPanel>
            </Grid>

            <!-- ===== Chart Area ===== -->
            <!-- ItemsControl renders bar groups horizontally -->
            <ItemsControl ItemsSource="{Binding ChartData}" Height="160">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center">
                            <!-- Dual bar group -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom">
                                <!-- Primary bar (darker blue) -->
                                <Border Width="16"
                                        Height="{Binding Bar1Height}"
                                        CornerRadius="3,3,0,0"
                                        Margin="1,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#3B82F6"/>
                                    </Border.Background>
                                </Border>

                                <!-- Secondary bar (lighter blue) -->
                                <Border Width="16"
                                        Height="{Binding Bar2Height}"
                                        CornerRadius="3,3,0,0"
                                        Margin="1,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#93C5FD"/>
                                    </Border.Background>
                                </Border>
                            </StackPanel>

                            <!-- Hour label -->
                            <TextBlock Text="{Binding Label}"
                                       FontFamily="{StaticResource DashFontFamily}"
                                       FontSize="11"
                                       Foreground="{StaticResource DashTextMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
