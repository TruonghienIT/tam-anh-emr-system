<UserControl x:Class="TamAnh_EMR_System.View.Components.ChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource DashCardStyle}">
        <StackPanel>

            <!-- ========================================================= -->
            <!-- HEADER -->
            <!-- ========================================================= -->

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Mật độ lịch khám (24h tới)"
                    FontFamily="{StaticResource DashFontFamily}"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{StaticResource DashTextPrimary}"
                    VerticalAlignment="Center"/>

                <!-- FILTER TABS -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button
                        Style="{StaticResource DashTabButtonActive}"
                        Content="Theo giờ"
                        Margin="0,0,4,0"/>

                    <Button
                        Style="{StaticResource DashTabButton}"
                        Content="Theo khoa"/>
                </StackPanel>
            </Grid>

            <!-- ========================================================= -->
            <!-- CHART AREA -->
            <!-- ========================================================= -->

            <Grid Height="260">

                <!-- ===================================================== -->
                <!-- LOADING SKELETON -->
                <!-- ===================================================== -->

                <Border
                    Background="#F3F4F6"
                    CornerRadius="12"
                    Padding="20">

                    <Border.Style>
                        <Style TargetType="Border">

                            <Setter Property="Visibility"
                                    Value="Collapsed"/>

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding IsChartLoading}"
                                    Value="True">

                                    <Setter Property="Visibility"
                                            Value="Visible"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>
                    </Border.Style>

                    <StackPanel>

                        <Rectangle
                            Height="20"
                            RadiusX="4"
                            RadiusY="4"
                            Fill="#E5E7EB"
                            Margin="0,0,0,16"/>

                        <Rectangle
                            Height="180"
                            RadiusX="8"
                            RadiusY="8"
                            Fill="#E5E7EB"/>

                    </StackPanel>

                </Border>

                <!-- ===================================================== -->
                <!-- REAL CHART -->
                <!-- ===================================================== -->

                <ItemsControl
                    ItemsSource="{Binding ChartData}">

                    <ItemsControl.Style>

                        <Style TargetType="ItemsControl">

                            <Setter Property="Visibility"
                                    Value="Visible"/>

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding IsChartLoading}"
                                    Value="True">

                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </ItemsControl.Style>

                    <!-- HORIZONTAL LAYOUT -->
                    <ItemsControl.ItemsPanel>

                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>

                    </ItemsControl.ItemsPanel>

                    <!-- ITEM TEMPLATE -->
                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Grid Margin="6">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- BAR AREA -->
                                <Grid Grid.Row="0"
                                      VerticalAlignment="Bottom"
                                      Height="190">

                                    <Border
                                        Width="32"
                                        Height="{Binding Height}"
                                        MinHeight="12"
                                        MaxHeight="180"
                                        Background="#3B82F6"
                                        CornerRadius="6,6,0,0"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"/>

                                </Grid>

                                <!-- LABEL -->
                                <TextBlock
                                    Grid.Row="1"
                                    Text="{Binding Label}"
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    FontSize="11"
                                    Foreground="#6B7280"/>

                            </Grid>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </Grid>

        </StackPanel>
    </Border>

</UserControl>