<UserControl x:Class="TamAnh_EMR_System.View.Components.ChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource DashCardStyle}">
        <StackPanel>

            <!-- ========================================================= -->
            <!-- HEADER -->
            <!-- ========================================================= -->

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Mật độ lịch khám (24h tới)"
                    FontFamily="{StaticResource DashFontFamily}"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{StaticResource DashTextPrimary}"
                    VerticalAlignment="Center"/>

                <!-- FILTER TABS -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button
                        Style="{StaticResource DashTabButtonActive}"
                        Content="Theo giờ"
                        Margin="0,0,4,0"/>

                    <Button
                        Style="{StaticResource DashTabButton}"
                        Content="Theo khoa"/>
                </StackPanel>
            </Grid>

            <!-- ========================================================= -->
            <!-- CHART AREA -->
            <!-- ========================================================= -->

            <Grid Height="280">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,5,40">
                    <TextBlock Text="Max" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="11" Foreground="#9CA3AF" Margin="0,15,0,0"/>
                    <TextBlock Text="50%" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,-20"/>
                    <TextBlock Text="0" VerticalAlignment="Bottom" HorizontalAlignment="Right" FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,0"/>
                </Grid>

                <Grid Grid.Column="1" Margin="0,20,0,40">
                    <Rectangle Height="1" Fill="#E5E7EB" VerticalAlignment="Top" StrokeDashArray="4 4"/>
                    <Rectangle Height="1" Fill="#E5E7EB" VerticalAlignment="Center" Margin="0,0,0,-20"/>
                    <Rectangle Height="1" Fill="#9CA3AF" VerticalAlignment="Bottom"/>
                </Grid>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0,4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="40" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" VerticalAlignment="Bottom" Height="220">
                                    <StackPanel VerticalAlignment="Bottom">

                                        <TextBlock Text="{Binding Value}" 
                                                   HorizontalAlignment="Center" 
                                                   FontSize="11" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#4B5563"
                                                   Margin="0,0,0,4"/>

                                        <Border Width="32"
                                                Height="{Binding BarHeight}"
                                                MinHeight="4"
                                                MaxHeight="180"
                                                Background="#3B82F6"
                                                CornerRadius="4,4,0,0"
                                                HorizontalAlignment="Center"
                                                ToolTip="{Binding Tooltip}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding Label}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="2,8,2,0"
                                           FontSize="11"
                                           Foreground="#6B7280"
                                           ToolTip="{Binding Label}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

        </StackPanel>
    </Border>

</UserControl>