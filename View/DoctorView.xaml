<Window x:Class="TamAnh_EMR_System.View.DoctorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:local="clr-namespace:TamAnh_EMR_System.View.Doctor"
        Title="Doctor Dashboard" Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F8F9FC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MenuButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" Padding="24,16" Margin="16,4,16,4" CornerRadius="8">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" 
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Background="#1D4ED8" CornerRadius="8" Margin="0,0,12,0">
                        <fa:IconImage Icon="Plus" Foreground="White" Width="18" Height="18"/>
                    </Border>
                    <TextBlock Text="TâmAnh Hospital" FontSize="16" FontWeight="Bold" Foreground="#1E3A8A" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">

                    <RadioButton x:Name="MenuTrangChu" GroupName="MainMenu" Style="{StaticResource MenuButton}" IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="TableCellsLarge" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Trang chủ" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="MenuQuanLyBenhNhan" GroupName="MainMenu" Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Users" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Quản lý bệnh nhân" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="MainMenu" Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Stethoscope" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Tư vấn" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="MenuDonThuoc" GroupName="MainMenu" Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FilePrescription" Width="18" Height="18" Margin="0,0,16,0"
                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Đơn thuốc" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="MainMenu" Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FolderOpen" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Hồ sơ bệnh án" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="MainMenu" Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ChartSimple" Width="18" Height="18" Margin="0,0,16,0"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                            <TextBlock Text="Phân tích" FontSize="15"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,0,0,24">
                    <Separator Margin="24,0,24,16" Background="#E5E7EB"/>
                    <RadioButton Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="CircleQuestion" Width="18" Height="18" Foreground="#6B7280" Margin="0,0,16,0"/>
                            <TextBlock Text="Hỗ trợ" FontSize="15" FontWeight="Medium" Foreground="#4B5563"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource MenuButton}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ArrowRightFromBracket" Width="18" Height="18" Foreground="#6B7280" Margin="0,0,16,0"/>
                            <TextBlock Text="Đăng xuất" FontSize="15" FontWeight="Medium" Foreground="#4B5563"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="28,0">
                <Grid>
                    <TextBlock Text="TâmAnh Hospital" FontSize="16" FontWeight="Bold" Foreground="#1E3A8A" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand">
                            <fa:IconImage Icon="Bell" Width="20" Height="20" Foreground="#6B7280"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand">
                            <fa:IconImage Icon="CircleQuestion" Width="20" Height="20" Foreground="#6B7280"/>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Margin="0,0,24,0" Cursor="Hand">
                            <fa:IconImage Icon="Gear" Width="20" Height="20" Foreground="#6B7280"/>
                        </Button>

                        <Border Width="1" Height="30" Background="#E5E7EB" Margin="0,0,24,0"/>

                        <TextBlock Text="BS Lê tân" FontSize="14" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="36" Height="36">
                            <Ellipse.Fill>
                                <ImageBrush Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </StackPanel>
                </Grid>
            </Border>

            <local:DoctorDashboardView Grid.Row="1" Loaded="DoctorDashboardView_Loaded"
                                       Visibility="{Binding IsChecked, ElementName=MenuTrangChu, Converter={StaticResource BoolToVis}}"/>

            <local:DoctorPatientManagementView Grid.Row="1" 
                                               Visibility="{Binding IsChecked, ElementName=MenuQuanLyBenhNhan, Converter={StaticResource BoolToVis}}"/>
            <local:PrescriptionView Grid.Row="1" 
                        Visibility="{Binding IsChecked, ElementName=MenuDonThuoc, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</Window>