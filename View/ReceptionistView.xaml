<Window x:Class="TamAnh_EMR_System.View.ReceptionistView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:TamAnh_EMR_System.View.Components"
        mc:Ignorable="d"
        Title="TâmAnh Hospital - Tổng quan Lịch khám"
        Height="800" Width="1280"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DashPageBackground}"
        FontFamily="{StaticResource DashFontFamily}">

    <!-- ================================================================
         RECEPTIONIST VIEW (Main Dashboard Window)
         
         This is a COMPOSITION view — it assembles reusable components
         into the final dashboard layout. No inline UI complexity here.
         
         Layout structure:
         ├── DockPanel
         │   ├── LEFT: SidebarControl (fixed 220px)
         │   └── RIGHT: Main content area
         │       ├── TOP: HeaderControl
         │       └── CONTENT: ScrollViewer
         │           ├── Dashboard title
         │           ├── StatisticCardControl (4 KPI cards)
         │           ├── AppointmentTableControl (data table)
         │           └── Bottom row (2 columns)
         │               ├── NotificationPanel
         │               └── ChartPanel
         
         DataContext is set in code-behind to ReceptionistDashboardViewModel.
         All child components inherit this DataContext automatically.
         ================================================================ -->

    <DockPanel LastChildFill="True">

        <!-- ===== LEFT SIDEBAR ===== -->
        <components:SidebarControl DockPanel.Dock="Left"/>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <DockPanel LastChildFill="True">

            <!-- ===== TOP HEADER ===== -->
            <components:HeaderControl DockPanel.Dock="Top"/>

            <!-- ===== DYNAMIC CONTENT AREA =====
                 ContentControl binds to CurrentView property in ViewModel.
                 
                 When sidebar menu is clicked:
                 1. MenuNavigateCommand fires
                 2. ExecuteMenuNavigate sets CurrentView to the target UserControl
                 3. ContentControl re-renders the new view
                 
                 CurrentView starts with DashboardContentControl (default).
                 "Đăng ký" sets it to RegisterPatientView.
                 All child views inherit DataContext from the ViewModel.
                 ===== -->
            <ContentControl Content="{Binding CurrentView}"/>
        </DockPanel>
    </DockPanel>
</Window>
