<UserControl x:Class="TamAnh_EMR_System.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Border Background="{StaticResource panelColor}"
            CornerRadius="15"
            Padding="15"
            Margin="0,10,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hệ thống quản lý bệnh án điện tử"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#B6A8E5"
                               Margin="0,5,0,10"
                               FontFamily="Montserrat"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"  
                    HorizontalAlignment="Right">

                    <TextBlock Text="{Binding CurrentDate}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#B6A8E5"
                    HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <UniformGrid Columns="4"
                                 Margin="0,10,0,25">
                        <Border Background="#6C63FF"
                                CornerRadius="24"
                                Padding="22"
                                Margin="0,0,18,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="55"
                                        Height="55"
                                        CornerRadius="27.5"
                                        Background="{StaticResource color3}">
                                    <fa:IconImage Icon="Users"
                                                  Width="26"
                                                  Height="26"
                                                  Foreground="White"
                                                  VerticalAlignment="Bottom"
                                                  HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="15,0,0,0">

                                    <TextBlock Text="Bệnh nhân"
                                               Foreground="#ECE9FF"
                                               FontSize="14"
                                               FontFamily="Montserrat"/>

                                    <TextBlock Text="{Binding PatientCount}"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               FontFamily="Montserrat"/>

                                    <TextBlock Text="{Binding PatientGrowth}"
                                               Foreground="#E4FFEA"
                                               FontSize="12"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Border Background="#3DA9FC"
                                CornerRadius="24"
                                Padding="22"
                                Margin="0,0,18,0">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="55"
                                        Height="55"
                                        CornerRadius="27.5"
                                        Background="{StaticResource color4}">

                                    <fa:IconImage Icon="CalendarCheck"
                                                  Width="24"
                                                  Height="24"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="15,0,0,0">

                                    <TextBlock Text="Lịch hẹn"
                                               Foreground="#EAF7FF"
                                               FontSize="14"/>

                                    <TextBlock Text="{Binding AppointmentCount}"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding AppointmentPending}"
                                               Foreground="#E4FFEA"
                                               FontSize="12"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Border Background="#F97316"
                                CornerRadius="24"
                                Padding="22"
                                Margin="0,0,18,0">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="55"
                                        Height="55"
                                        CornerRadius="27.5"
                                        Background="{StaticResource color8}">

                                    <fa:IconImage Icon="FileWaveform"
                                                  Width="24"
                                                  Height="24"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="15,0,0,0">

                                    <TextBlock Text="Bệnh án"
                                               Foreground="#FFEAF4"
                                               FontSize="14"/>

                                    <TextBlock Text="{Binding MedicalRecordCount}"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding MedicalRecordToday}"
                                               Foreground="#E4FFEA"
                                               FontSize="12"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                        <Border Background="#9B5DE5"
                                CornerRadius="24"
                                Padding="22">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="55"
                                        Height="55"
                                        CornerRadius="27.5"
                                        Background="{StaticResource color2}">

                                    <fa:IconImage Icon="UserDoctor"
                                                  Width="24"
                                                  Height="24"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="15,0,0,0">

                                    <TextBlock Text="Bác sĩ"
                                               Foreground="#F2EAFF"
                                               FontSize="14"/>

                                    <TextBlock Text="{Binding DoctorCount}"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="White"/>

                                    <TextBlock Text="{Binding DoctorSpecializationInfo}"
                                                Foreground="#E4FFEA"
                                                FontSize="12"/>
                                </StackPanel>

                            </Grid>
                        </Border>

                    </UniformGrid>


                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Border Background="{StaticResource panelOverColor}"
                                    CornerRadius="28"
                                    Padding="25"
                                    Margin="0,0,20,20">
                                <StackPanel>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Thống kê bệnh nhân"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ChartTypes}"
                                                  SelectedItem="{Binding SelectedChartType}"
                                                  Height="38"
                                                  Background="{StaticResource panelColor}"
                                                  Foreground="White"
                                                  BorderThickness="0"
                                                  FontFamily="Montserrat"
                                                  FontSize="13"
                                                  Cursor="Hand">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Padding" Value="12,8"/>
                                                    <Setter Property="FontFamily" Value="Montserrat"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource panelOverColor}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#6C63FF"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>

                                            <ComboBox.Template>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="12"
                                                            BorderBrush="#3A3263"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="40"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ContentPresenter Margin="14,0,0,0"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Left"
                                                                              Content="{TemplateBinding SelectionBoxItem}"/>
                                                            <Grid Grid.Column="1">
                                                                <Path Data="M 0 0 L 4 4 L 8 0"
                                                                      Stroke="#B6A8E5"
                                                                      StrokeThickness="2"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <ToggleButton Grid.ColumnSpan="2"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        Focusable="False"
                                                                        OverridesDefaultStyle="True"
                                                                        Cursor="Hand"
                                                                        IsChecked="{Binding IsDropDownOpen,
                                                                        RelativeSource={RelativeSource TemplatedParent},
                                                                        Mode=TwoWay}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                   Placement="Bottom"
                                                                   AllowsTransparency="True"
                                                                   Focusable="False"
                                                                   PopupAnimation="Fade">
                                                                <Border Margin="0,6,0,0"
                                                                        Background="{StaticResource panelColor}"
                                                                        CornerRadius="12"
                                                                        BorderBrush="#3A3263"
                                                                        BorderThickness="1">
                                                                    <ScrollViewer Margin="4">
                                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#6C63FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ComboBox.Template>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Height="260">

                                        <StackPanel VerticalAlignment="Stretch">

                                            <Border Height="1"
                                                    Background="#FFFFFF15"
                                                    Margin="0,25"/>

                                            <Border Height="1"
                                                    Background="#FFFFFF15"
                                                    Margin="0,25"/>

                                            <Border Height="1"
                                                    Background="#FFFFFF15"
                                                    Margin="0,25"/>

                                            <Border Height="1"
                                                    Background="#FFFFFF15"
                                                    Margin="0,25"/>
                                        </StackPanel>

                                        <Canvas Height="220" Background="Transparent">

                                            <ItemsControl ItemsSource="{Binding PatientBars}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemContainerStyle>
                                                    <Style>
                                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>

                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Value}"
                                                                       FontSize="13"
                                                                       Foreground="{StaticResource color7}"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,0,0,2"/>

                                                            <Rectangle Width="{Binding Width}"
                                                                       Height="{Binding Height}"
                                                                       Fill="DodgerBlue"
                                                                       RadiusX="4"
                                                                       RadiusY="4"/>

                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="13"
                                                                       Foreground="#B6A8E5"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,5,0,0"/>
                                                        </StackPanel>

                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>

                                            </ItemsControl>
                                        </Canvas>

                                    </Grid>

                                </StackPanel>

                            </Border>

                            <Border Background="{StaticResource panelOverColor}"
                                    CornerRadius="28"
                                    Padding="25"
                                    Margin="0,0,20,20">

                                <StackPanel>

                                    <!-- HEADER -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Lịch hẹn hôm nay"
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Foreground="White"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="Xem tất cả"
                                                   Foreground="#8F7DFF"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Cursor="Hand"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding RecentAppointments}">

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Border Background="{StaticResource color2}"
                                                    CornerRadius="16"
                                                    Padding="15"
                                                    Margin="0,0,0,10">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*"/>
                                                            <ColumnDefinition Width="2*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Patient.Name}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Reason}"
                                                                   Foreground="#B6A8E5"/>

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding AppointmentTime}"
                                                                   Foreground="#3DA9FC"
                                                                   FontWeight="Bold"/>

                                                        <Border Grid.Column="3"
                                                                CornerRadius="10"
                                                                Padding="8,3"
                                                                HorizontalAlignment="Right">

                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#3BCF7A"/>

                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                            <Setter Property="Background" Value="#FFB84D"/>
                                                                        </DataTrigger>

                                                                        <DataTrigger Binding="{Binding Status}" Value="Waiting">
                                                                            <Setter Property="Background" Value="#FF5EA8"/>
                                                                        </DataTrigger>

                                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                            <Setter Property="Background" Value="#3BCF7A"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <TextBlock Text="{Binding Status}"
                                           Foreground="White"
                                           FontSize="11"/>

                                                        </Border>

                                                    </Grid>

                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>

                                    </ItemsControl>

                                </StackPanel>

                            </Border>

                        </StackPanel>

                        <StackPanel Grid.Column="1">

                            <Border Background="{StaticResource panelOverColor}"
                                    CornerRadius="28"
                                    Padding="25"
                                    Margin="0,0,0,20">

                                <StackPanel>

                                    <TextBlock Text="Hoạt động gần đây"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,20"/>

                                    <!--<Border Background="{StaticResource color2}"
                                            CornerRadius="16"
                                            Padding="14"
                                            Margin="0,0,0,12">

                                        <StackPanel Orientation="Horizontal">

                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="21"
                                                    Background="#3DA9FC22">

                                                <fa:IconImage Icon="FileCirclePlus"
                                                              Foreground="#3DA9FC"
                                                              Width="18"
                                                              Height="18"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Margin="12,0,0,0">

                                                <TextBlock Text="Tạo bệnh án mới"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock Text="2 phút trước"
                                                           Foreground="#A6A6D1"
                                                           FontSize="12"/>
                                            </StackPanel>

                                        </StackPanel>

                                    </Border>

                                    <Border Background="{StaticResource color2}"
                                            CornerRadius="16"
                                            Padding="14">

                                        <StackPanel Orientation="Horizontal">

                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="21"
                                                    Background="#FF5EA822">

                                                <fa:IconImage Icon="CalendarPlus"
                                                              Foreground="#FF5EA8"
                                                              Width="18"
                                                              Height="18"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Margin="12,0,0,0">

                                                <TextBlock Text="Đặt lịch khám"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock Text="10 phút trước"
                                                           Foreground="#A6A6D1"
                                                           FontSize="12"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>-->

                                    <ItemsControl ItemsSource="{Binding RecentActivities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource color2}"
                                                        CornerRadius="16"
                                                        Padding="14"
                                                        Margin="0,0,0,12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="42"
                                                            Height="42"
                                                            CornerRadius="21"
                                                            Background="{Binding DotColor}"
                                                            Margin="0,0,12,0">

                                                            <fa:IconImage Icon="{Binding Icon}"
                                                                          Width="18"
                                                                          Height="18"
                                                                          Foreground="White"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="White"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="14"/>
                                                            <TextBlock Text="{Binding Description}"
                                                                        Foreground="#B6A8E5"
                                                                        FontSize="12"
                                                                        Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding TimeText}"
                                                                       Foreground="#8A84B8"
                                                                       FontSize="11"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource panelOverColor}"
                                    CornerRadius="28"
                                    Padding="25">
                                <StackPanel>
                                    <TextBlock Text="Tiến độ hôm nay"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,20"/>

                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="Lịch khám hoàn thành"
                                                   Foreground="#D9D4FF"
                                                   Margin="0,0,0,8"/>

                                        <ProgressBar Value="75"
                                                     Height="10"
                                                     Background="#2E1B5B"
                                                     Foreground="#6C63FF"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="Bệnh án cập nhật"
                                                   Foreground="#D9D4FF"
                                                   Margin="0,0,0,8"/>

                                        <ProgressBar Value="60"
                                                     Height="10"
                                                     Background="#2E1B5B"
                                                     Foreground="#3DA9FC"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Bệnh nhân đã tiếp nhận"
                                                   Foreground="#D9D4FF"
                                                   Margin="0,0,0,8"/>

                                        <ProgressBar Value="90"
                                                     Height="10"
                                                     Background="#2E1B5B"
                                                     Foreground="#FF5EA8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>