<UserControl x:Class="TamAnh_EMR_System.View.MedicalRecordPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TamAnh_EMR_System.Converters"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:TamAnh_EMR_System.View"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LeftText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2FFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Grid.Column="0">
                <fa:IconImage Icon="Search" Height="20" Width="20" Foreground="{StaticResource plainTextColor3}"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Width="320"
                         Height="24"
                         Background="Transparent"
                         FontWeight="Medium"
                         FontFamily="Montserrat"
                         Foreground="{StaticResource plainTextColor3}"
                         CaretBrush="{StaticResource plainTextColor3}"
                         BorderBrush="{StaticResource plainTextColor3}"
                         BorderThickness="0,0,0,1"
                         VerticalContentAlignment="Center"
                         Margin="5,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Border Grid.Row="1"
                Background="{StaticResource panelColor}"
                CornerRadius="15"
                Padding="15"
                Margin="0,10,0,0">

            <DataGrid ItemsSource="{Binding MedicalRecords}"
                      SelectedItem="{Binding SelectedMedicalRecord}"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      Foreground="{StaticResource titleColor1}"
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="42"
                      RowHeaderWidth="0"
                      CanUserAddRows="False"
                      SelectionMode="Single">

                <!-- MODERN SCROLL -->
                <DataGrid.Resources>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ModernScrollViewer}"/>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernScrollBar}"/>
                </DataGrid.Resources>

                <!-- HEADER STYLE -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="{StaticResource plainTextColor3}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>

                </DataGrid.ColumnHeaderStyle>

                <!-- ROW STYLE -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource panelOverColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource panelActiveColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- CELL STYLE -->
                <DataGrid.CellStyle>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{StaticResource color8}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontFamily" Value="Montserrat"/>
                        <Setter Property="Margin" Value="10,0,0,0"/>
                    </Style>

                </DataGrid.CellStyle>

                <!-- COLUMNS -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bệnh nhân" Binding="{Binding Patient.Name}" Width="*" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Bác sĩ" Binding="{Binding Doctor.FullName}" Width="180" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Mã ICD" Binding="{Binding IcdCode}" Width="100" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Bệnh" Binding="{Binding Disease.DiseaseName}" Width="180" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Chẩn đoán" Binding="{Binding Diagnosis}" Width="220" ElementStyle="{StaticResource LeftText}"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt,StringFormat=dd/MM/yyyy   HH:mm}" Width="150" ElementStyle="{StaticResource LeftText}"/>

                    <DataGridTemplateColumn Header="Thao tác" Width="120">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FontFamily" Value="Montserrat"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="Foreground" Value="{StaticResource plainTextColor3}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding DataContext.ViewMedicalRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,5,0">
                                        <fa:IconImage Icon="Eye" Foreground="#2196F3" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding DataContext.EditMedicalRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,5,0">
                                        <fa:IconImage Icon="PenToSquare" Foreground="#4CAF50" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding DataContext.DeleteMedicalRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <fa:IconImage Icon="RectangleXmark" Foreground="#F44336" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        
        <Grid Grid.RowSpan="2"
              Panel.ZIndex="999"
              Visibility="{Binding IsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#66000000">

            <Border Width="950" Height="680" CornerRadius="20" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource color8}" CornerRadius="20,0,0,20" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <Ellipse Width="150" Height="150">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Resource/Image/medical-record.jpg" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>

                            <TextBlock Text="{Binding PopupTitle}"
                               FontSize="18"
                               FontFamily="Montserrat"
                               FontWeight="Bold"
                               Margin="0,20,0,5"
                               TextAlignment="Center"/>

                            <TextBlock Text="Thông tin hồ sơ bệnh án"
                               FontSize="12"
                               FontFamily="Montserrat"
                               TextAlignment="Center"
                               Opacity="0.7"/>

                        </StackPanel>

                    </Border>

                    <Grid Grid.Column="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Style="{StaticResource controlButton}"
                                Command="{Binding ClosePopupCommand}"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0">
                            <fa:IconImage Icon="CircleXmark" Style="{StaticResource controlButtonIcon}" Width="20" Height="20"/>
                        </Button>

                        <ScrollViewer Grid.Row="1"
                              Style="{StaticResource ModernScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,10,0,0">

                            <StackPanel>
                                <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Bệnh nhân" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.Patient.Name}" IsReadOnly="True"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Bác sĩ phụ trách" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.Doctor.FullName}" IsReadOnly="True"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="HeartPulse" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Triệu chứng &amp; Dấu hiệu sinh tồn" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>

                                <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Mạch (lần/phút)" FontSize="12" Foreground="#6B7280"/>
                                                <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.Pulse}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Huyết áp (mmHg)" FontSize="12" Foreground="#6B7280"/>
                                                <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.BloodPressure}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Nhiệt độ (°C)" FontSize="12" Foreground="#6B7280"/>
                                                <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.Temperature}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="6">
                                                <TextBlock Text="SpO2 (%)" FontSize="12" Foreground="#6B7280"/>
                                                <TextBox Style="{StaticResource InputTextBox}" Text="{Binding CurrentMedicalRecord.SPO2}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="Flask" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Xét nghiệm lâm sàng"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#111827"/>
                                </StackPanel>
                                    <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding CurrentMedicalRecord.LabResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,10">
                                                            <TextBlock Text="Tên xét nghiệm" FontSize="12" Foreground="#6B7280"/>
                                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding TestName}" Margin="0,4,0,8"/>
                                                            <TextBlock Text="Kết quả" FontSize="12" Foreground="#6B7280"/>
                                                            <TextBox Style="{StaticResource InputTextBox}" Height="60" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding Result}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="Stethoscope" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Chuẩn đoán" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>

                                <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Mã bệnh (ICD)" FontSize="12" Foreground="#6B7280"/>
                                                <ComboBox ItemsSource="{Binding DiseaseList}"
                                                        SelectedValue="{Binding CurrentMedicalRecord.IcdCode, Mode=TwoWay}"
                                                        SelectedValuePath="IcdCode"
                                                        Background="White"
                                                        BorderBrush="#E5E7EB"
                                                        BorderThickness="1"
                                                        Padding="14,8"
                                                        Height="40"
                                                        FontSize="12"
                                                        Cursor="Hand">

                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding IcdCode}" FontWeight="Bold"/>
                                                                <TextBlock Text=" - " />
                                                                <TextBlock Text="{Binding DiseaseName}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>

                                                    <ComboBox.Template>
                                                        <ControlTemplate TargetType="ComboBox">
                                                            <Grid>
                                                                <ToggleButton x:Name="ToggleButton" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Background="Transparent" BorderThickness="0" Focusable="False">

                                                                    <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="28"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock VerticalAlignment="Center" Foreground="#111827" Text="{Binding SelectedItem.IcdCode, RelativeSource={RelativeSource TemplatedParent}}" />
                                                                            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </ToggleButton>
                                                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False">

                                                                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                                                        <ScrollViewer MaxHeight="220">
                                                                            <ItemsPresenter/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>

                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#93C5FD"/>
                                                                </Trigger>
                                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ComboBox.Template>

                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Tên bệnh" FontSize="12" Foreground="#6B7280"/>
                                                <TextBox Style="{StaticResource InputTextBox}"
                                                    Text="{Binding CurrentMedicalRecord.Disease.DiseaseName}"
                                                    IsReadOnly="True"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Mô tả bệnh" FontSize="12" Foreground="#6B7280"/>
                                        <TextBox Style="{StaticResource InputTextBox}" Height="70" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding CurrentMedicalRecord.Diagnosis}"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="NotesMedical" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Phương pháp điều trị" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                                <TextBox Style="{StaticResource InputTextBox}" Height="90" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding CurrentMedicalRecord.Treatment}" Margin="0,0,0,24"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <fa:IconImage Icon="PenToSquare" Width="16" Height="16" Foreground="#2563EB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ghi chú / Lời dặn" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                </StackPanel>
                                <TextBox Style="{StaticResource InputTextBox}" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding CurrentMedicalRecord.Notes}" Margin="0,0,0,24"/>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15,0,0"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Hủy" Command="{Binding ClosePopupCommand}" Width="80" Height="30" Margin="0,0,10,0"/>
                            <Button Content="Lưu" Command="{Binding SaveMedicalRecordCommand}" Width="80" Height="30" Background="#28C76F" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
