<Window x:Class="TamAnh_EMR_System.View.Doctor.AddPrescriptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="Cấu hình Đơn thuốc" Height="620" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F4F8FB" FontFamily="Segoe UI" FontSize="14"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#004C99"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#333333"/>
        <SolidColorBrush x:Key="TextGreyBrush" Color="#777777"/>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <fa:IconImage Icon="PrescriptionBottleMedical" Width="22" Height="22" Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="Kê đơn thuốc cho bệnh nhân" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
            </StackPanel>
            <TextBlock Text="Chọn thuốc từ danh mục hệ thống và cấu hình chi tiết liều dùng." FontSize="13" Foreground="{StaticResource TextGreyBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Tên thuốc" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="CmbMedicines" DisplayMemberPath="Name" SelectedValuePath="Id" Height="38" Background="White" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Số lượng (Viên)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtQuantity" Style="{StaticResource InputTextBox}" Height="38"/>
                </StackPanel>

                <Grid Grid.Row="2" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Liều lượng (dosage)" FontSize="12" Foreground="{StaticResource TextGreyBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtDosage" Style="{StaticResource InputTextBox}" Height="38" Text="500mg"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tần suất (frequency)" FontSize="12" Foreground="{StaticResource TextGreyBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtFrequency" Style="{StaticResource InputTextBox}" Height="38" Text="2 lần/ngày"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Ghi chú / Lời dặn (notes)" FontSize="12" Foreground="{StaticResource TextGreyBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtNotes" Style="{StaticResource InputTextBox}" Height="38" Text="Uống sau ăn"/>
                    </StackPanel>

                    <Button Grid.Column="6" Style="{StaticResource BaseButton}" Background="{StaticResource PrimaryBlueBrush}" Foreground="White" Padding="20,0" Height="38" VerticalAlignment="Bottom" Click="BtnAddMedicine_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Width="12" Height="12" Foreground="White" Margin="0,0,6,0"/>
                            <TextBlock Text="Thêm" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="DgPrescription" AutoGenerateColumns="False" CanUserAddRows="False" Background="Transparent" BorderThickness="0" RowHeight="40" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên thuốc" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Số lượng" Binding="{Binding QuantityDisplay}" Width="1*"/>
                    <DataGridTextColumn Header="Liều lượng" Binding="{Binding Dosage}" Width="1.2*"/>
                    <DataGridTextColumn Header="Hướng dẫn &amp; Lời dặn" Binding="{Binding Instruction}" Width="3*"/>
                    <DataGridTemplateColumn Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Xóa" Foreground="#EF4444" Background="Transparent" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Click="BtnRemoveMedicine_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy bỏ" Style="{StaticResource BaseButton}" Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20,10" Margin="0,0,12,0" Click="BtnCancel_Click"/>
            <Button Content="Áp dụng đơn thuốc" Style="{StaticResource BaseButton}" Background="#10B981" Foreground="White" Padding="24,10" FontWeight="Bold" Click="BtnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>