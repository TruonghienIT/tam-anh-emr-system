<UserControl x:Class="TamAnh_EMR_System.View.Doctor.ConsultationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="#F8F9FC" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="B" TargetType="Button"><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value>
            <ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.9"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SI" TargetType="TextBox"><Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="36,10,14,10"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                <Border x:Name="Bx" Background="White" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Padding="{TemplateBinding Padding}">
                    <Grid><ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    <TextBlock x:Name="P" Text="{TemplateBinding Tag}" Foreground="#9CA3AF" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/></Grid>
                </Border><ControlTemplate.Triggers>
                    <Trigger Property="Text" Value=""><Setter TargetName="P" Property="Visibility" Value="Visible"/></Trigger>
                    <Trigger Property="Text" Value="{x:Null}"><Setter TargetName="P" Property="Visibility" Value="Visible"/></Trigger>
                    <Trigger Property="IsFocused" Value="True"><Setter TargetName="Bx" Property="BorderBrush" Value="#3B82F6"/></Trigger>
                </ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <!-- Vital input -->
        <Style x:Key="VI" TargetType="TextBox"><Setter Property="Height" Value="40"/><Setter Property="FontSize" Value="15"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#111827"/><Setter Property="Padding" Value="10,8"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="BorderBrush" Value="#E5E7EB"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Background" Value="White"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                <Border x:Name="VB" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsFocused" Value="True"><Setter TargetName="VB" Property="BorderBrush" Value="#3B82F6"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <!-- ===== SCAN SECTION (TOP) ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="240"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="🏥" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="Quét mã để bắt đầu khám" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                    <TextBlock Text="Đưa mã QR bệnh án vào máy quét, hoặc nhập thủ công bên dưới." FontSize="12" Foreground="#6B7280" Margin="0,0,0,14" TextWrapping="Wrap"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource SI}" Text="{Binding ScanCode, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập / quét mã vạch..."/>
                            <TextBlock Text="📋" FontSize="14" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="2" Style="{StaticResource B}" Background="#3B82F6" Padding="20,10" BorderThickness="0" Command="{Binding ScanCommand}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="MagnifyingGlass" Width="14" Height="14" Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="Quét mã" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Barcode card -->
            <Border Grid.Column="2" Background="White" CornerRadius="14" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="QR bệnh án" FontSize="9" Foreground="#9CA3AF" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border Height="60" Width="160" Margin="0,0,0,8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="║║║║║║║║║║║║║║║" FontSize="18" Foreground="#111827" FontFamily="Consolas" HorizontalAlignment="Center"/>
                            <TextBlock Text="║║║║║║║║║║║║║║║" FontSize="18" Foreground="#111827" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,-6,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="HS-19283-44" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== MAIN CONTENT (QUEUE + EMR) ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <!-- LEFT: PATIENT QUEUE -->
            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="18,16" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
                <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Calendar" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,8,0"/>
                            <TextBlock Text="Lịch khám của tôi" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                        <Border CornerRadius="10" Padding="8,3" Background="#EFF6FF" HorizontalAlignment="Right">
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="#3B82F6">
                                <Run Text="{Binding WaitingCount}"/><Run Text=" Chờ"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding QueuePatients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectPatientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,0,8">
                                    <Button.Template><ControlTemplate TargetType="Button">
                                        <Border x:Name="QR" CornerRadius="10" Padding="12,10" BorderThickness="1">
                                            <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F9FAFB"/><Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#3B82F6"/></DataTrigger></Style.Triggers>
                                            </Style></Border.Style>
                                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <!-- Avatar -->
                                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <Border.Background><SolidColorBrush Color="{Binding AvatarColor}"/></Border.Background>
                                                    <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="#111827"/>
                                                    <TextBlock Text="{Binding GenderAge}" FontSize="11" Foreground="#6B7280" Margin="0,1,0,0"/>
                                                    <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="#F59E0B" Margin="0,2,0,0">
                                                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="ĐANG KHÁM"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                                        </Style.Triggers></Style></TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Time + Status -->
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                                    <Border CornerRadius="8" Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#EFF6FF"/>
                                                            <Style.Triggers><DataTrigger Binding="{Binding Status}" Value="ĐANG KHÁM"><Setter Property="Background" Value="#FEF3C7"/></DataTrigger></Style.Triggers>
                                                        </Style></Border.Style>
                                                        <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold">
                                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#3B82F6"/>
                                                                <Style.Triggers><DataTrigger Binding="{Binding Status}" Value="ĐANG KHÁM"><Setter Property="Foreground" Value="#D97706"/></DataTrigger></Style.Triggers>
                                                            </Style></TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="QR" Property="Background" Value="#F0F9FF"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate></Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- RIGHT: EMR DETAIL -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="14" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <!-- PATIENT HEADER -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#6366F1" Margin="0,0,14,0">
                            <fa:IconImage Icon="User" Width="24" Height="24" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap">
                                <Run Text="Bệnh án điện tử cho"/><Run Text="{Binding Consultation.PatientName}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,4,0,0">
                                <Run Text="🏥 ID: "/><Run Text="{Binding Consultation.PatientId}"/>
                                <Run Text="   📅 "/><Run Text="{Binding Consultation.BirthDate}"/>
                                <Run Text=" ("/><Run Text="{Binding Consultation.Age}"/><Run Text="t)"/>
                                <Run Text="   ♂ "/><Run Text="{Binding Consultation.Gender}"/>
                                <Run Text="   ⊕ "/><Run Text="{Binding Consultation.BloodType}"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="8" Padding="10,6" Background="#EFF6FF" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Consultation.Insurance}" FontSize="11" FontWeight="Bold" Foreground="#3B82F6"/>
                        </Border>
                    </Grid>

                    <!-- VITAL SIGNS -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconImage Icon="HeartPulse" Width="16" Height="16" Foreground="#EF4444" Margin="0,0,8,0"/>
                        <TextBlock Text="Triệu chứng &amp; Dấu hiệu sinh tồn" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"><TextBlock Text="Mạch (lần/phút)" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource VI}" Text="{Binding Consultation.VitalSigns.Pulse, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Huyết áp (mmHg)" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource VI}" Text="{Binding Consultation.VitalSigns.BloodPressure, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Column="4"><TextBlock Text="Nhiệt độ (°C)" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Consultation.VitalSigns.Temperature, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" FontWeight="SemiBold" Padding="10,8" VerticalContentAlignment="Center" BorderThickness="1">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Foreground" Value="#111827"/><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                                        <Border x:Name="TB" CornerRadius="6" Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/></Border>
                                    </ControlTemplate></Setter.Value></Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Consultation.VitalSigns.IsTemperatureHigh, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Foreground" Value="#EF4444"/><Setter Property="Background" Value="#FEF2F2"/><Setter Property="BorderBrush" Value="#FECACA"/>
                                        </DataTrigger>
                                    </Style.Triggers></Style></TextBox.Style>
                            </TextBox></StackPanel>
                        <StackPanel Grid.Column="6"><TextBlock Text="SpO2 (%)" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource VI}" Text="{Binding Consultation.VitalSigns.SpO2, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    </Grid>

                    <!-- SYMPTOMS CHECKBOXES -->
                    <ItemsControl ItemsSource="{Binding Consultation.Symptoms}" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,16,6" Cursor="Hand">
                                    <CheckBox.Template><ControlTemplate TargetType="CheckBox">
                                        <Border x:Name="CB" CornerRadius="6" Padding="10,6" BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="Ck" Width="18" Height="18" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Margin="0,0,6,0">
                                                    <TextBlock x:Name="Cm" Text="✓" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Visibility="Collapsed"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CB" Property="Background" Value="#EFF6FF"/><Setter TargetName="CB" Property="BorderBrush" Value="#3B82F6"/>
                                                <Setter TargetName="Ck" Property="Background" Value="#3B82F6"/><Setter TargetName="Ck" Property="BorderBrush" Value="#3B82F6"/>
                                                <Setter TargetName="Cm" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate></CheckBox.Template>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- DIAGNOSIS -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconImage Icon="Stethoscope" Width="14" Height="14" Foreground="#3B82F6" Margin="0,0,8,0"/>
                        <TextBlock Text="Chuẩn đoán" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource SI}" Tag="" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="14,10"
                             Text="{Binding Consultation.Diagnosis, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                    <!-- NOTES -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconImage Icon="NoteSticky" Width="14" Height="14" Foreground="#3B82F6" Margin="0,0,8,0"/>
                        <TextBlock Text="Ghi chú / Lời dặn" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                    <TextBox Style="{StaticResource SI}" Tag="" Height="50" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="14,10"
                             Text="{Binding Consultation.Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                    <!-- ACTION BUTTONS -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource B}" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="16,10" Command="{Binding ViewHistoryCommand}">
                            <StackPanel Orientation="Horizontal"><fa:IconImage Icon="ClockRotateLeft" Width="14" Height="14" Foreground="#6B7280" Margin="0,0,6,0"/>
                                <TextBlock Text="Lịch sử khám" FontSize="13" Foreground="#374151" FontWeight="SemiBold"/></StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource B}" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="16,10" Command="{Binding CreatePrescriptionCommand}">
                            <StackPanel Orientation="Horizontal"><fa:IconImage Icon="FilePrescription" Width="14" Height="14" Foreground="#6B7280" Margin="0,0,6,0"/>
                                <TextBlock Text="Kê toa thuốc" FontSize="13" Foreground="#374151" FontWeight="SemiBold"/></StackPanel>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource B}" Background="#3B82F6" Padding="20,10" BorderThickness="0" Command="{Binding SaveRecordCommand}">
                            <StackPanel Orientation="Horizontal"><fa:IconImage Icon="FloppyDisk" Width="14" Height="14" Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="Lưu bệnh án" FontSize="13" Foreground="White" FontWeight="SemiBold"/></StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
