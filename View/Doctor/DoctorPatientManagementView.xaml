 <UserControl x:Class="TamAnh_EMR_System.View.Doctor.DoctorPatientManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="#F8F9FC" FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,40,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <fa:IconImage Icon="Qrcode" Width="20" Height="20" Foreground="#1E3A8A" Margin="0,0,8,0"/>
                        <TextBlock Text="Quét mã để bắt đầu khám" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    </StackPanel>
                    <TextBlock Text="Đưa mã QR bệnh án vào máy quét, hoặc nhập thủ công bên dưới." 
                               FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource InputTextBox}" Background="#F3F4F6" BorderThickness="0"
                                 Text="Nhập / quét mã vạch..." Foreground="#9CA3AF" FontSize="14"/>
                        <Button Grid.Column="2" Style="{StaticResource BaseButton}" Background="#2563EB" Foreground="White" Padding="24,10" Command="{Binding ScanQrCommand}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="MagnifyingGlass" Width="14" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Quét mã" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="8" Height="120">
                    <Grid>
                        <Path Data="M 20 10 L 10 10 L 10 20 M 330 10 L 340 10 L 340 20 M 10 100 L 10 110 L 20 110 M 340 100 L 340 110 L 330 110" 
                              Stroke="#2563EB" StrokeThickness="2" Stretch="Fill" Margin="20"/>

                        <Border Background="White" Width="200" Height="70" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.1"/>
                            </Border.Effect>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="QR BỆNH ÁN" FontSize="9" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <fa:IconImage Icon="Qrcode" Width="120" Height="24" Foreground="#374151"/>
                                <TextBlock Text="HS-19283-44" FontSize="9" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Rectangle Fill="#EF4444" Height="2" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="CalendarDay" Width="16" Height="16" Foreground="#2563EB" Margin="0,0,8,0"/>
                            <TextBlock Text="Lịch khám của tôi" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                        <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding WaitingCount, StringFormat='{}{0} Chờ'}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#1E3A8A"/>
                        </Border>
                    </Grid>

                    <ListBox Grid.Row="2" ItemsSource="{Binding PatientQueue}" SelectedItem="{Binding SelectedPatient}" 
                             BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                    <Setter Property="BorderThickness" Value="4,1,1,1"/>
                                                    <Setter Property="BorderBrush">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#2563EB" Offset="0.02"/>
                                                                <GradientStop Color="#E5E7EB" Offset="0.02"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="40" Height="40" CornerRadius="20" Margin="0,0,12,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#E5E7EB"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="#111827"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#111827"/>
                                            <TextBlock Text="{Binding InfoString}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <fa:IconImage Width="12" Height="12" Margin="0,0,4,0">
                                                    <fa:IconImage.Style>
                                                        <Style TargetType="fa:IconImage">
                                                            <Setter Property="Icon" Value="None"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Khẩn cấp">
                                                                    <Setter Property="Icon" Value="TriangleExclamation"/>
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </fa:IconImage.Style>
                                                </fa:IconImage>
                                                <TextBlock Text="{Binding Reason}" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4B5563"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Khẩn cấp">
                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#6B7280" HorizontalAlignment="Right"/>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}">
                                            </StackPanel>

                                            <ComboBox Width="85"
                                                    Height="26"
                                                    Margin="0,8,0,0"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"
                                                    SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectedValuePath="Content"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    BorderThickness="0"
                                                    HorizontalAlignment="Right"
                                                    VerticalContentAlignment="Center"
                                                    Padding="0"
                                                    Cursor="Hand"
                                                    IsEditable="False">

                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                        <Setter Property="Foreground" Value="#1E3A8A"/>

                                                        <Style.Triggers>

                                                            <DataTrigger Binding="{Binding Status}" Value="Đang chờ">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                                <Setter Property="Foreground" Value="#92400E"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Status}" Value="Đang khám">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                                <Setter Property="Foreground" Value="#1E3A8A"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                                <Setter Property="Foreground" Value="#065F46"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Status}" Value="Đã hủy">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                                <Setter Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>

                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>

                                                <ComboBox.Template>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <ToggleButton x:Name="ToggleButton"
                                                                          Focusable="False"
                                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          ClickMode="Press"
                                                                          Background="{TemplateBinding Background}"
                                                                          BorderThickness="0">

                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="6"
                                                                        Padding="8,4">

                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="14"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <ContentPresenter Grid.Column="0"
                                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                                          HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"/>

                                                                        <Path Grid.Column="1"
                                                                                VerticalAlignment="Center"
                                                                                HorizontalAlignment="Center"
                                                                                Fill="{TemplateBinding Foreground}"
                                                                                Data="M 0 0 L 4 4 L 8 0 Z"/>
                                                                    </Grid>
                                                                </Border>
                                                            </ToggleButton>

                                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                   Placement="Bottom"
                                                                   AllowsTransparency="True"
                                                                   Focusable="False"
                                                                   PopupAnimation="Slide">

                                                                <Border Background="White"
                                                                        BorderBrush="#E5E7EB"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6"
                                                                        Margin="0,2,0,0">

                                                                    <ScrollViewer MaxHeight="200">
                                                                        <StackPanel IsItemsHost="True"/>
                                                                    </ScrollViewer>

                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ComboBox.Template>

                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Padding" Value="6"/>
                                                        <Setter Property="Cursor" Value="Hand"/>

                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBoxItem">
                                                                    <Border x:Name="Bd"
                                                                            Background="White"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Border>

                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsHighlighted" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                                                        </Trigger>

                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>

                                                <ComboBoxItem Content="Đang chờ"/>
                                                <ComboBoxItem Content="Đang khám"/>
                                                <ComboBoxItem Content="Hoàn thành"/>
                                                <ComboBoxItem Content="Đã hủy"/>

                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.04"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F5FF" Padding="24" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="70" Height="70" CornerRadius="8" Margin="0,0,20,0" ClipToBounds="True">
                                <Rectangle Fill="#1E3A8A"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,8">
                                    <Run Text="Bệnh án điện tử cho"/>
                                    <Run Text="{Binding SelectedPatient.Name, FallbackValue='(Chưa chọn)'}"/>
                                </TextBlock>

                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="IdCard" Width="12" Height="12" Foreground="#6B7280" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SelectedPatient.AppointmentId, StringFormat='ID: {0}', FallbackValue='N/A'}" FontSize="13" Foreground="#4B5563" Margin="0,0,16,0"/>

                                    <fa:IconImage Icon="CakeCandles" Width="12" Height="12" Foreground="#6B7280" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SelectedPatient.DOBString, FallbackValue='N/A'}" FontSize="13" Foreground="#4B5563" Margin="0,0,16,0"/>

                                    <fa:IconImage Icon="Droplet" Width="12" Height="12" Foreground="#6B7280" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SelectedPatient.BloodType, FallbackValue='N/A'}" FontSize="13" Foreground="#4B5563"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#DBEAFE" CornerRadius="16" Padding="12,6" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ShieldHeart" Width="14" Height="14" Foreground="#1E3A8A" Margin="0,0,6,0"/>
                                    <TextBlock Text="BHYT Hợp lệ" FontSize="12" FontWeight="Bold" Foreground="#1E3A8A"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <fa:IconImage Icon="HeartPulse" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="Triệu chứng &amp; Dấu hiệu sinh tồn" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                            </StackPanel>

                            <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Mạch (lần/phút)" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding Pulse}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Huyết áp (mmHg)" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding BloodPressure}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Nhiệt độ (°C)" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding Temperature}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="6">
                                            <TextBlock Text="SpO2 (%)" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}" Text="{Binding SPO2}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <fa:IconImage Icon="Flask" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="Xét nghiệm lâm sàng"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#111827"/>
                            </StackPanel>
                            <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Tên xét nghiệm" FontSize="12" Foreground="#6B7280"/>
                                    <TextBox Style="{StaticResource InputTextBox}" Text="{Binding LabTestName}" Margin="0,4,0,12"/>
                                    <TextBlock Text="Kết quả xét nghiệm" FontSize="12"  Foreground="#6B7280"/>
                                    <TextBox Style="{StaticResource InputTextBox}" Height="70" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding LabResult}"/>
                                </StackPanel>
                            </Border>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <fa:IconImage Icon="Stethoscope" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="Chuẩn đoán" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                            </StackPanel>

                            <Border Background="#F3F6F9" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Mã bệnh (ICD)" FontSize="12" Foreground="#6B7280"/>
                                            <ComboBox ItemsSource="{Binding DiseaseList}"
                                                      SelectedItem="{Binding SelectedDisease, Mode=TwoWay}"
                                                      Background="White"
                                                      BorderBrush="#E5E7EB"
                                                      BorderThickness="1"
                                                      Padding="14,8"
                                                      Height="40"
                                                      FontSize="12"
                                                      VerticalContentAlignment="Center"
                                                      Cursor="Hand">

                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding IcdCode}" FontWeight="Bold"/>
                                                            <TextBlock Text=" - " />
                                                            <TextBlock Text="{Binding DiseaseName}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>

                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox">

                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Padding" Value="14,10"/>

                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBox">

                                                                    <Grid>

                                                                        <ToggleButton x:Name="ToggleButton"
                                                                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                    Focusable="False"
                                                                                    Background="Transparent"
                                                                                    BorderThickness="0">

                                                                            <Border x:Name="Border"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="6"
                                                                                    Padding="{TemplateBinding Padding}">

                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="28"/>
                                                                                    </Grid.ColumnDefinitions>

                                                                                    <TextBlock Margin="10,0"
                                                                                               VerticalAlignment="Center"
                                                                                               HorizontalAlignment="Left"
                                                                                               Text="{Binding SelectedItem.IcdCode, RelativeSource={RelativeSource TemplatedParent}}" />

                                                                                    <Path Grid.Column="1"
                                                                                            Data="M 0 0 L 4 4 L 8 0 Z"
                                                                                            Fill="#6B7280"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"/>
                                                                                </Grid>
                                                                            </Border>
                                                                        </ToggleButton>

                                                                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                                                            <Border Background="White"
                                                                                    BorderBrush="#E5E7EB"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6"
                                                                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                                                                <ScrollViewer MaxHeight="220">
                                                                                    <ItemsPresenter/>
                                                                                </ScrollViewer>
                                                                            </Border>
                                                                        </Popup>
                                                                    </Grid>

                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#93C5FD"/>
                                                                        </Trigger>

                                                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                                                        </Trigger>

                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Tên bệnh" FontSize="12" Foreground="#6B7280"/>
                                            <TextBox Style="{StaticResource InputTextBox}"
                                                    Text="{Binding DiseaseName}"
                                                    IsReadOnly="True"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Mô tả bệnh" FontSize="12" Foreground="#6B7280"/>
                                    <TextBox Style="{StaticResource InputTextBox}" Height="70" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding DiagnosisDescription}"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <fa:IconImage Icon="NotesMedical" Width="18" Height="18" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="Phương pháp điều trị" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource InputTextBox}" Height="90" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding TreatmentPlan}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <fa:IconImage Icon="PenToSquare" Width="16" Height="16" Foreground="#2563EB" Margin="0,0,8,0"/>
                                <TextBlock Text="Ghi chú / Lời dặn" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource InputTextBox}" Height="80" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding NotesText}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource BaseButton}"
                                        Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Padding="16,10"
                                        Margin="0,0,12,0">

                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="PrescriptionBottleMedical"
                                                      Width="14"
                                                      Height="14"
                                                      Foreground="#2563EB"
                                                      Margin="0,0,8,0"/>
                                        <TextBlock Text="Kê toa thuốc"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2563EB"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource BaseButton}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        Padding="20,10"
                                        Command="{Binding SaveRecordCommand}">

                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconImage Icon="FloppyDisk"
                                                      Width="14"
                                                      Height="14"
                                                      Foreground="White"
                                                      Margin="0,0,8,0"/>
                                        <TextBlock Text="Lưu bệnh án" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>