<UserControl x:Class="TamAnh_EMR_System.View.Doctor.DoctorAppointmentView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="clr-namespace:TamAnh_EMR_System.Converters"
			 xmlns:local="clr-namespace:TamAnh_EMR_System.View.Doctor"
			 Background="#F8F9FC" FontFamily="Segoe UI">

	<UserControl.Resources>
		<conv:InitialsConverter x:Key="InitialsConverter"/>
		<conv:StatusToVietnameseConverter x:Key="StatusToVietnameseConverter"/>

		<SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
		<SolidColorBrush x:Key="TextMainBrush" Color="#111827"/>
		<SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>

		<Style x:Key="FlatButton" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Foreground" Value="#3B82F6"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#EFF6FF"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
			<Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#1D4ED8"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="GridViewColumnHeader">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#6B7280"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="12,16,12,16"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="BorderBrush" Value="#E5E7EB"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="GridViewColumnHeader">
						<Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="TableListViewItem" TargetType="ListViewItem">
			<Setter Property="Background" Value="White"/>
			<Setter Property="Margin" Value="0"/>
			<Setter Property="Padding" Value="0,16"/>
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="BorderBrush" Value="#F3F4F6"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListViewItem">
						<Border BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
							<GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#F9FAFB"/>
				</Trigger>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#EFF6FF"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	<Grid Margin="20">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,20,0" VerticalAlignment="Top">
			<Border.Effect>
				<DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="10" ShadowDepth="2"/>
			</Border.Effect>
            <StackPanel>
                <TextBlock Text="Bộ lọc tìm kiếm" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="Từ ngày" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding FromDate}" Height="36" Margin="0,0,0,12"/>

                <TextBlock Text="Đến ngày" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding ToDate}" Height="36"/>

                <Separator Margin="0,16" Background="#E5E7EB"/>

                <TextBlock Text="Trạng thái" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,0,0,4"/>
                <ComboBox SelectedValue="{Binding StatusFilter}" SelectedValuePath="Content" Height="36" Padding="8,6">
                    <ComboBoxItem Content="Tất cả"/>
                    <ComboBoxItem Content="Đang chờ"/>
                    <ComboBoxItem Content="Đang khám"/>
                    <ComboBoxItem Content="Hoàn thành"/>
                    <ComboBoxItem Content="Đã hủy"/>
                </ComboBox>

                <Separator Margin="0,16" Background="#E5E7EB"/>

                <Button Content="Tải lại dữ liệu" Command="{Binding RefreshCommand}" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="0,10" Foreground="#374151" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

		<Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="0">
			<Border.Effect>
				<DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1"/>
			</Border.Effect>

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<Grid Margin="24,20,24,16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="Danh sách khám hôm nay" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
				</Grid>

				<ListView Grid.Row="1" ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}"
                          BorderThickness="0" Background="Transparent" Padding="12,0"
                          ItemContainerStyle="{StaticResource TableListViewItem}"
				   ScrollViewer.HorizontalScrollBarVisibility="Auto">
					<ListView.View>
						<GridView>
							<GridViewColumn Header="THỜI GIAN" Width="120">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Margin="12,0,0,0">
											<TextBlock Text="{Binding AppointmentTime}" FontWeight="Bold" FontSize="15" Foreground="#111827"/>
											<TextBlock Text="{Binding AppointmentDate, StringFormat='{}{0:dd/MM/yyyy}'}" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0"/>
										</StackPanel>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>

							<GridViewColumn Header="BỆNH NHÂN" Width="280">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
											<Grid Width="40" Height="40">
												<Ellipse Fill="#EEF2FF"/>
												<TextBlock Text="{Binding PatientName, Converter={StaticResource InitialsConverter}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="Bold" Foreground="#4F46E5" FontSize="14"/>
											</Grid>

											<StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
												<TextBlock Text="{Binding PatientName}" FontWeight="Bold" FontSize="14" Foreground="#111827"/>
												<TextBlock Text="Nam, 32 tuổi" FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
											</StackPanel>
										</StackPanel>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>

							<GridViewColumn Header="BÁC SĨ" Width="200">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
											<TextBlock Text="{Binding DoctorName}" FontWeight="Medium" Foreground="#374151"/>
											<TextBlock Text="{Binding Department}" FontSize="12" Foreground="#9CA3AF" FontStyle="Italic" Margin="0,4,0,0"/>
										</StackPanel>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>

							<GridViewColumn Header="DỊCH VỤ" Width="160">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<Border Background="#F3F4F6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="12,0,0,0">
											<TextBlock Text="{Binding Reason}" FontSize="12" FontWeight="Medium" Foreground="#4B5563"/>
										</Border>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>

                            <GridViewColumn Header="TRẠNG THÁI" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="StatusBg" Background="#EFF6FF" CornerRadius="12" Padding="8,4" HorizontalAlignment="Left" Margin="12,0,0,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#3B82F6" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="StatusTxt" Text="{Binding Status, Converter={StaticResource StatusToVietnameseConverter}}" FontWeight="Medium" FontSize="12" Foreground="#1D4ED8"/>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Đang chờ">
                                                <Setter TargetName="StatusBg" Property="Background" Value="#FEF3C7"/>
                                                <Setter TargetName="StatusDot" Property="Fill" Value="#D97706"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="#B45309"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Đang khám">
                                                <Setter TargetName="StatusBg" Property="Background" Value="#DBEAFE"/>
                                                <Setter TargetName="StatusDot" Property="Fill" Value="#3B82F6"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="#1D4ED8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Hoàn thành">
                                                <Setter TargetName="StatusBg" Property="Background" Value="#DCFCE7"/>
                                                <Setter TargetName="StatusDot" Property="Fill" Value="#16A34A"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="#15803D"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Đã hủy">
                                                <Setter TargetName="StatusBg" Property="Background" Value="#FEE2E2"/>
                                                <Setter TargetName="StatusDot" Property="Fill" Value="#EF4444"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="#B91C1C"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
					</ListView.View>
				</ListView>
			</Grid>
		</Border>
	</Grid>
</UserControl>