<UserControl x:Class="TamAnh_EMR_System.View.Receptionist.SearchPatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="#F8F9FC" FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- Tái sử dụng Style chung cho Button cơ bản -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Button Template cho ComboBox -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Border x:Name="templateRoot" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" SnapsToDevicePixels="true">
                <fa:IconImage x:Name="arrow" Icon="ChevronDown" Width="10" Height="10" Foreground="#6B7280" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter TargetName="arrow" Property="Foreground" Value="#111827"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Style ComboBox Xanh nhạt -->
        <Style x:Key="BlueComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                            <Border x:Name="MainBorder" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <ContentPresenter x:Name="contentPresenter" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" HorizontalAlignment="Left" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" IsHitTestVisible="false"/>
                                    <ToggleButton x:Name="toggleButton" Template="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Focusable="false"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" CornerRadius="8" Margin="0,4,0,0" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=templateRoot}" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="4" Opacity="0.05"/>
                                    </Border.Effect>
                                    <ScrollViewer x:Name="DropDownScrollViewer" Margin="0,4">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0"/>
                                            <ItemsPresenter x:Name="itemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style ComboBox Xám nhạt -->
        <Style x:Key="GreyComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource BlueComboBoxStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="true">
                            <Border x:Name="MainBorder" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <ContentPresenter x:Name="contentPresenter" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" HorizontalAlignment="Left" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" IsHitTestVisible="false"/>
                                    <ToggleButton x:Name="toggleButton" Template="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Focusable="false"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" CornerRadius="8" Margin="0,4,0,0" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{Binding ActualWidth, ElementName=templateRoot}" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="4" Opacity="0.05"/>
                                    </Border.Effect>
                                    <ScrollViewer x:Name="DropDownScrollViewer" Margin="0,4">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0"/>
                                            <ItemsPresenter x:Name="itemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,32,40,40">

                <!-- Header Section -->
                <TextBlock Text="Tiếp nhận bệnh nhân" FontSize="32" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Tìm kiếm cơ sở dữ liệu lâm sàng cho bệnh nhân hiện có hoặc bắt đầu đăng ký mới cho khách hàng vừa đến."
                           FontSize="15" Foreground="#6B7280" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="600" Margin="0,0,0,36"/>

                <!-- Top Action Cards -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Đăng ký -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="28,24" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="12" Background="#EFF6FF" Margin="0,0,0,20" HorizontalAlignment="Left">
                                <fa:IconImage Icon="UserPlus" Width="20" Height="20" Foreground="#2563EB"/>
                            </Border>
                            <TextBlock Text="Đăng ký bệnh nhân mới" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            <TextBlock Text="Tiếp nhận khách hàng mới. Thu thập thông tin nhân khẩu học, bảo hiểm và chấp thuận y tế."
                                       FontSize="14" Foreground="#6B7280" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,20"/>
                            <Button Style="{StaticResource Btn}" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Left" Command="{Binding StartRegistrationCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Bắt đầu đăng ký" FontSize="14" Foreground="#2563EB" FontWeight="SemiBold"/>
                                    <fa:IconImage Icon="ArrowRight" Width="12" Height="12" Foreground="#2563EB" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Xác nhận lịch hẹn -->
                    <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="28,24" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="12" Background="#ECFDF5" Margin="0,0,0,20" HorizontalAlignment="Left">
                                <fa:IconImage Icon="CircleCheck" Width="22" Height="22" Foreground="#10B981"/>
                            </Border>
                            <TextBlock Text="Xác nhận lịch hẹn" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>
                            <TextBlock Text="Xác nhận sự hiện diện cho các cuộc hẹn đã lên lịch. Xác minh danh tính và cập nhật trạng thái."
                                       FontSize="14" Foreground="#6B7280" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,20"/>
                            <Button Style="{StaticResource Btn}" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Left" Command="{Binding ConfirmAppointmentCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Xử lý đến nơi" FontSize="14" Foreground="#2563EB" FontWeight="SemiBold"/>
                                    <fa:IconImage Icon="ArrowRight" Width="12" Height="12" Foreground="#2563EB" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Thống kê nhanh -->
                    <Border Grid.Column="4" CornerRadius="16" Padding="28,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="16" Opacity="0.2" Color="#1D4ED8"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="TỔNG QUAN LỄ TÂN" FontSize="11" Foreground="#DBEAFE" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock Text="Lượng bệnh nhân" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding CheckedInToday}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Đã check-in" FontSize="13" Foreground="#DBEAFE" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding WaitingCount}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Đang chờ" FontSize="13" Foreground="#DBEAFE" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Main Data Section -->
                <Border Background="White" CornerRadius="16" Padding="28" BorderThickness="1" BorderBrush="#E5E7EB">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.02" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Search and Filters -->
                        <Border Padding="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Search Box -->
                                <Border Grid.Column="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Height="42">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <fa:IconImage Icon="Search" Width="14" Height="14" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent" Foreground="#111827" CaretBrush="#111827" 
                                                 FontSize="14" VerticalContentAlignment="Center" Padding="0,0,16,0"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <ComboBox Grid.Column="2" Style="{StaticResource BlueComboBoxStyle}" ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding SelectedGender}" />
                                <ComboBox Grid.Column="4" Style="{StaticResource GreyComboBoxStyle}" ItemsSource="{Binding BloodOptions}" SelectedItem="{Binding SelectedBlood}" />
                            </Grid>
                        </Border>

                        <!-- Loading State -->
                        <StackPanel Margin="0,0,0,20" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Height="18" Background="#F8FAFC" CornerRadius="4" Margin="0,0,0,12"/>
                            <Border Height="18" Background="#F8FAFC" CornerRadius="4" Margin="0,0,0,12"/>
                            <Border Height="18" Background="#F8FAFC" CornerRadius="4" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- Empty State -->
                        <Border Margin="0,80" Visibility="{Binding PagedPatients.Count, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <fa:IconImage Icon="FolderOpen" Width="64" Height="64" Foreground="#D1D5DB" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                                <TextBlock Text="Không tìm thấy dữ liệu" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hãy thử thay đổi từ khóa hoặc thiết lập lại bộ lọc" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid -->
                        <Border BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Background="White">

                            <Grid>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DataGrid ItemsSource="{Binding PagedPatients}"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          BorderThickness="0"
                                          Background="White"
                                          GridLinesVisibility="None"
                                          RowHeight="56"
                                          ColumnHeaderHeight="48"
                                          FontSize="14"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="Padding" Value="16,0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#F3F4F6"/>

                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="16,0"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Foreground" Value="#111827"/>
                                        </Style>
                                    </DataGrid.CellStyle>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mã BN" Binding="{Binding Id}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#111827"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Họ tên" Binding="{Binding Name}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#111827"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Giới tính" Binding="{Binding Gender}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#111827"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Ngày sinh" Binding="{Binding Dob, StringFormat=dd/MM/yyyy}" Width="140">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#111827"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#111827"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Nhóm máu" Binding="{Binding BloodType}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="Thao tác" Width="200">
                                            <DataGridTemplateColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>

                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Width="70"
                                                        Height="30"
                                                        Margin="0,0,8,0"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.EditPatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bg" Background="#EFF6FF" CornerRadius="6">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <fa:IconImage Icon="PenToSquare" Width="12" Height="12" Foreground="#2563EB" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="Sửa" Foreground="#2563EB" FontWeight="SemiBold" FontSize="12"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="#DBEAFE"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Button Width="70"
                                                                Height="30"
                                                                Cursor="Hand"
                                                                Command="{Binding DataContext.DeletePatientCommand,
                                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bg" Background="#FEF2F2" CornerRadius="6">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <fa:IconImage Icon="TrashCan" Width="12" Height="12" Foreground="#DC2626" Margin="0,0,6,0"/>
                                                                            <TextBlock Text="Xóa" Foreground="#DC2626" FontWeight="SemiBold" FontSize="12"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="#FEE2E2"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- PAGINATION -->
                                <Border Grid.Row="1"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="0,1,0,0"
                                        Padding="16"
                                        Background="White">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding PaginationText}" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding PageNumbers}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Width="34"
                                                            Height="34"
                                                            Margin="3,0"
                                                            Content="{Binding}"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.NavigatePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">

                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bg"
                                                                        Background="White"
                                                                        BorderBrush="#E5E7EB"
                                                                        BorderThickness="1"
                                                                        CornerRadius="6">

                                                                    <TextBlock Text="{Binding}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#111827"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bg" Property="Background" Value="#F8FAFC"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid>
            <ItemsControl ItemsSource="{Binding Toasts}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,24,24,0" Panel.ZIndex="999">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="320" Margin="0,0,0,12" Padding="20,16" CornerRadius="8" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.1" Color="#000000"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Message}" Foreground="#F8FAFC" TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>