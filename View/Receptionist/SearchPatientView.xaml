<UserControl x:Class="TamAnh_EMR_System.View.Receptionist.SearchPatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="#F8F9FC" FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="SI" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="40,12,14,12"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                <Border x:Name="B" Background="White" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Padding="{TemplateBinding Padding}">
                    <Grid><ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    <TextBlock x:Name="P" Text="{TemplateBinding Tag}" Foreground="#9CA3AF" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/></Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="Text" Value=""><Setter TargetName="P" Property="Visibility" Value="Visible"/></Trigger>
                    <Trigger Property="Text" Value="{x:Null}"><Setter TargetName="P" Property="Visibility" Value="Visible"/></Trigger>
                    <Trigger Property="IsFocused" Value="True"><Setter TargetName="B" Property="BorderBrush" Value="#3B82F6"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="Button"><Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Opacity" Value="0.9"/></Trigger></ControlTemplate.Triggers>
                </ControlTemplate></Setter.Value></Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="40,32,40,40">

        <!-- ===== HEADER ===== -->
        <TextBlock Text="Tiếp nhận bệnh nhân" FontSize="28" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,16,0,12"/>
        <TextBlock Text="Tìm kiếm cơ sở dữ liệu lâm sàng cho bệnh nhân hiện có hoặc bắt đầu đăng ký mới cho khách hàng vừa đến."
                   FontSize="14" Foreground="#6B7280" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="550" Margin="0,0,0,28"/>

        <!-- ===== SEARCH BAR ===== -->
        <Border Background="White" CornerRadius="12" Padding="6" BorderBrush="#E5E7EB" BorderThickness="1" HorizontalAlignment="Center" MinWidth="700" Margin="0,0,0,40">
            <Border.Effect><DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.08"/></Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource SI}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Tag="Tìm theo tên, ngày sinh hoặc mã bệnh nhân"/>
                    <fa:IconImage Icon="MagnifyingGlass" Width="16" Height="16" Foreground="#9CA3AF" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                </Grid>
                <!-- Bộ lọc -->
                <Button Grid.Column="1" Style="{StaticResource Btn}" Background="Transparent" Padding="14,10" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Sliders" Width="14" Height="14" Foreground="#6B7280" Margin="0,0,6,0"/>
                        <TextBlock Text="Bộ lọc" FontSize="13" Foreground="#6B7280"/>
                    </StackPanel>
                </Button>
                <!-- Tìm kiếm -->
                <Button Grid.Column="2" Style="{StaticResource Btn}" Background="#1E293B" Padding="20,10" BorderThickness="0" Command="{Binding SearchCommand}">
                    <TextBlock Text="Tìm kiếm" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Border>

        <!-- ===== QUICK ACTION CARDS ===== -->
        <Grid Margin="0,0,0,32">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <!-- Card 1: Đăng ký bệnh nhân mới -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10" Background="#EFF6FF" Margin="0,0,0,16" HorizontalAlignment="Left">
                        <fa:IconImage Icon="UserPlus" Width="18" Height="18" Foreground="#3B82F6"/>
                    </Border>
                    <TextBlock Text="Đăng ký bệnh nhân mới" FontSize="17" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="Tiếp nhận khách hàng mới. Thu thập thông tin nhân khẩu học, bảo hiểm và chấp thuận lịch sử y tế."
                               FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,16"/>
                    <Button Style="{StaticResource Btn}" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Left" Command="{Binding StartRegistrationCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Bắt đầu đăng ký" FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                            <TextBlock Text="  →" FontSize="13" Foreground="#3B82F6"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Card 2: Xác nhận lịch hẹn -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10" Background="#ECFDF5" Margin="0,0,0,16" HorizontalAlignment="Left">
                        <fa:IconImage Icon="CircleCheck" Width="18" Height="18" Foreground="#10B981"/>
                    </Border>
                    <TextBlock Text="Xác nhận lịch hẹn" FontSize="17" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,8"/>
                    <TextBlock Text="Xác nhận sự hiện diện cho các cuộc hẹn đã lên lịch. Xác minh danh tính và cập nhật trạng thái 'Đang chờ'."
                               FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,16"/>
                    <Button Style="{StaticResource Btn}" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Left" Command="{Binding ConfirmAppointmentCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Xử lý đến nơi" FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                            <TextBlock Text=" →" FontSize="13" Foreground="#3B82F6"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Card 3: Lượng bệnh nhân (blue) -->
            <Border Grid.Column="4" CornerRadius="12" Padding="24,20">
                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#3B82F6" Offset="0"/><GradientStop Color="#2563EB" Offset="1"/></LinearGradientBrush></Border.Background>
                <Border.Effect><DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.15" Color="#3B82F6"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="TỔNG QUAN LỄ TÂN TRONG NGÀY" FontSize="10" Foreground="#93C5FD" FontWeight="SemiBold" Margin="0,0,0,6" LetterSpacing="0.5"/>
                    <TextBlock Text="Lượng bệnh nhân" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding CheckedInToday}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Đã check-in hôm nay" FontSize="11" Foreground="#BFDBFE" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding WaitingCount}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Trong phòng chờ" FontSize="11" Foreground="#BFDBFE" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== RECENT PATIENTS TABLE ===== -->
        <Border Background="White" CornerRadius="12" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06"/></Border.Effect>
            <StackPanel>
                <!-- Table header -->
                <Grid Margin="0,0,0,16">
                    <StackPanel><TextBlock Text="Bệnh nhân gần đây" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="10 bệnh nhân được truy cập hoặc sửa đổi gần nhất" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/></StackPanel>
                    <Button Style="{StaticResource Btn}" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding ViewSearchHistoryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Xem lịch sử tìm kiếm" FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <fa:IconImage Icon="ClockRotateLeft" Width="14" Height="14" Foreground="#3B82F6"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Column headers -->
                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,10,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TÊN BỆNH NHÂN" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="1" Text="MÃ BN/MRN" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="2" Text="NGÀY SINH" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="3" Text="LẦN KHÁM CUỐI" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="4" Text="THAO TÁC" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Patient rows -->
                <ItemsControl ItemsSource="{Binding Patients}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="1.5*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + Avatar -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0">
                                            <Border.Background><SolidColorBrush Color="{Binding AvatarColor}"/></Border.Background>
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Patient Code -->
                                    <TextBlock Grid.Column="1" Text="{Binding PatientCode}" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>

                                    <!-- DOB -->
                                    <TextBlock Grid.Column="2" Text="{Binding DateOfBirthText}" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>

                                    <!-- Last Visit Badge -->
                                    <Border Grid.Column="3" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Background><SolidColorBrush Color="{Binding LastVisitBg}"/></Border.Background>
                                        <TextBlock Text="{Binding LastVisitText}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Foreground><SolidColorBrush Color="{Binding LastVisitColor}"/></TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>

                                    <!-- Action -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Cursor="Hand" Command="{Binding DataContext.CheckInCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <Button.Template><ControlTemplate TargetType="Button">
                                                <Border x:Name="AB" Background="Transparent" Padding="8,4" CornerRadius="4">
                                                    <TextBlock x:Name="AT" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsCheckedIn}" Value="False">
                                                        <Setter TargetName="AT" Property="Text" Value="Check-in"/>
                                                        <Setter TargetName="AT" Property="Foreground" Value="#3B82F6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCheckedIn}" Value="True">
                                                        <Setter TargetName="AT" Property="Text" Value="Đã check-in"/>
                                                        <Setter TargetName="AT" Property="Foreground" Value="#9CA3AF"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="AB" Property="Background" Value="#F3F4F6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate></Button.Template>
                                        </Button>
                                        <Button Cursor="Hand" Margin="4,0,0,0">
                                            <Button.Template><ControlTemplate TargetType="Button">
                                                <Border x:Name="MB" Background="Transparent" Padding="4" CornerRadius="4">
                                                    <fa:IconImage Icon="EllipsisVertical" Width="14" Height="14" Foreground="#9CA3AF"/>
                                                </Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="MB" Property="Background" Value="#F3F4F6"/></Trigger></ControlTemplate.Triggers>
                                            </ControlTemplate></Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
