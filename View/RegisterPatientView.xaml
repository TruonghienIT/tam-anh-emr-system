<UserControl x:Class="TamAnh_EMR_System.View.RegisterPatientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="#F8F9FC"
             FontFamily="Segoe UI">

    <UserControl.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="CaretBrush" Value="#111827"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                <TextBlock x:Name="Ph" Text="{TemplateBinding Tag}" Foreground="#9CA3AF" FontSize="14" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormInputIcon" TargetType="TextBox" BasedOn="{StaticResource FormInput}">
            <Setter Property="Padding" Value="42,0,14,0"/>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                <Path Data="M0,0 L4,4 L8,0 Z" Fill="#6B7280" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0" />
            </Border>
        </ControlTemplate>

        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="MainBorder" Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" IsHitTestVisible="false"/>
                                    <ToggleButton Template="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Focusable="false"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" Margin="0,4,0,0">
                                <Border MinWidth="{Binding ActualWidth, ElementName=MainBorder}" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepItem" TargetType="Border">
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FormOutlineBtn" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="White" CornerRadius="10" BorderBrush="#D1D5DB" BorderThickness="1" Padding="24,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24,32,32">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Bệnh nhân" FontSize="13" Foreground="#9CA3AF"/>
                <TextBlock Text="  ›  " FontSize="13" Foreground="#9CA3AF"/>
                <TextBlock Text="Đăng ký mới" FontSize="13" Foreground="#6B7280" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Thông tin Bệnh nhân" FontSize="26" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Hoàn thành tất cả các mục bắt buộc để tạo hồ sơ bệnh nhân mới." FontSize="14" Foreground="#6B7280" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="500"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,8,0,0">
                    <Border Style="{StaticResource StepItem}" BorderBrush="#3B82F6">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="User" Width="16" Height="16" Foreground="#3B82F6" Margin="0,0,10,0"/>
                            <TextBlock Text="Thông tin cá nhân" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StepItem}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="AddressCard" Width="16" Height="16" Foreground="#9CA3AF" Margin="0,0,10,0"/>
                            <TextBlock Text="Thông tin liên hệ" FontSize="14" Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StepItem}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="NotesMedical" Width="16" Height="16" Foreground="#9CA3AF" Margin="0,0,10,0"/>
                            <TextBlock Text="Thông tin y tế" FontSize="14" Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">

                    <Border Background="White" CornerRadius="16" Padding="32,28" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,24">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <fa:IconImage Icon="User" Width="16" Height="16" Foreground="#3B82F6"/>
                                </Border>
                                <TextBlock Text="Thông tin cá nhân" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="HỌ"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.LastName, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập họ"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="TÊN"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.FirstName, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập tên"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="NGÀY SINH"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <Border CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB" Height="46">
                                        <DatePicker SelectedDate="{Binding Patient.DateOfBirth}" FontSize="14" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Margin="8,0"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="GIỚI TÍNH"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <ComboBox Style="{StaticResource FormCombo}" ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding Patient.Gender}" Text="Chọn giới tính" IsEditable="False"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="16" Padding="32,28" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,24">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <fa:IconImage Icon="AddressCard" Width="16" Height="16" Foreground="#3B82F6"/>
                                </Border>
                                <TextBlock Text="Thông tin liên hệ" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="EMAIL"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <Grid>
                                        <TextBox Style="{StaticResource FormInputIcon}" Text="{Binding Patient.Email, UpdateSourceTrigger=PropertyChanged}" Tag="abc@example.com"/>
                                        <fa:IconImage Icon="Envelope" Width="14" Height="14" Foreground="#9CA3AF" HorizontalAlignment="Left" Margin="16,0,0,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="SỐ ĐIỆN THOẠI"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                    <Grid>
                                        <TextBox Style="{StaticResource FormInputIcon}" Text="{Binding Patient.Phone, UpdateSourceTrigger=PropertyChanged}" Tag="+84 000 000 000"/>
                                        <fa:IconImage Icon="Phone" Width="14" Height="14" Foreground="#9CA3AF" HorizontalAlignment="Left" Margin="16,0,0,0" IsHitTestVisible="False"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Style="{StaticResource FieldLabel}"><Run Text="ĐỊA CHỈ"/><Run Text=" *" Foreground="#EF4444"/></TextBlock>
                                <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.Address, UpdateSourceTrigger=PropertyChanged}" Tag="Địa chỉ, Số nhà, Tên đường"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="NGƯỜI LIÊN HỆ KHẨN CẤP"/>
                                    <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.EmergencyContactName, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập tên người liên hệ"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="SĐT KHẨN CẤP"/>
                                    <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập số điện thoại"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="16" Padding="32,28" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,24">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF" Margin="0,0,12,0">
                                    <fa:IconImage Icon="NotesMedical" Width="16" Height="16" Foreground="#3B82F6"/>
                                </Border>
                                <TextBlock Text="Thông tin y tế bổ sung" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="SỐ CCCD/CMND"/>
                                    <TextBox Style="{StaticResource FormInput}" Text="{Binding Patient.IdCard, UpdateSourceTrigger=PropertyChanged}" Tag="012345678901"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="NHÓM MÁU"/>
                                    <ComboBox Style="{StaticResource FormCombo}" ItemsSource="{Binding BloodTypeOptions}" SelectedItem="{Binding Patient.BloodType}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="DỊ ỨNG"/>
                                <TextBox Style="{StaticResource FormInput}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="14,12" Text="{Binding Patient.Allergies, UpdateSourceTrigger=PropertyChanged}" Tag="Thông tin dị ứng thuốc/thực phẩm (nếu có)"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#FEF2F2" CornerRadius="10" BorderBrush="#FECACA" BorderThickness="1" Padding="20,16" Margin="0,0,0,16" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" FontSize="14" Foreground="#991B1B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#ECFDF5" CornerRadius="10" BorderBrush="#A7F3D0" BorderThickness="1" Padding="20,16" Margin="0,0,0,16" Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" FontSize="16" FontWeight="Bold" Foreground="#10B981" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SuccessMessage}" TextWrapping="Wrap" FontSize="14" Foreground="#065F46" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource FormOutlineBtn}" Content="Xóa form" Command="{Binding ClearFormCommand}"/>
                        <Button Grid.Column="2" Style="{StaticResource FormOutlineBtn}" Content="Phần trước" Command="{Binding PreviousCommand}"/>

                        <Button Grid.Column="4" Height="48" MinWidth="200" Command="{Binding SubmitCommand}" IsEnabled="{Binding IsNotLoading}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#3B82F6" CornerRadius="10" Padding="32,0">
                                        <TextBlock x:Name="BtnText" Text="{Binding SubmitButtonText}" Foreground="White" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Background" Value="#93C5FD"/>
                                            <Setter TargetName="BtnText" Property="Text" Value="Đang lưu..."/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>